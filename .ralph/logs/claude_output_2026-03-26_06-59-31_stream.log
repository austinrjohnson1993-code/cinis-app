{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TpfTzbzxVz3xfQxsoJHfgC","type":"tool_result","content":"   100→        entries.forEach((entry) => {\n   101→          if (entry.isIntersecting) {\n   102→            entry.target.classList.add('revealed')\n   103→          }\n   104→        })\n   105→      },\n   106→      { threshold: 0.2 }\n   107→    )\n   108→\n   109→    Object.values(revealRefs.current).forEach((ref) => {\n   110→      if (ref) observer.observe(ref)\n   111→    })\n   112→\n   113→    return () => observer.disconnect()\n   114→  }, [])\n   115→\n   116→  useEffect(() => {\n   117→    if (typeof window === 'undefined') return\n   118→    const move = (e) => {\n   119→      const el = document.getElementById('cursor-glow')\n   120→      if (el) {\n   121→        el.style.left = e.clientX + 'px'\n   122→        el.style.top = e.clientY + 'px'\n   123→      }\n   124→    }\n   125→    window.addEventListener('mousemove', move)\n   126→    return () => window.removeEventListener('mousemove', move)\n   127→  }, [])\n   128→\n   129→  const handleSubmit = async (e) => {\n   130→    e.preventDefault()\n   131→    if (!email.includes('@')) {\n   132→      setError('Please enter a valid email')\n   133→      return\n   134→    }\n   135→\n   136→    setLoading(true)\n   137→    setError('')\n   138→\n   139→    try {\n   140→      const response = await fetch('/api/waitlist', {\n   141→        method: 'POST',\n   142→        headers: { 'Content-Type': 'application/json' },\n   143→        body: JSON.stringify({ email, phone }),\n   144→      })\n   145→\n   146→      if (response.ok) {\n   147→        setFormSubmitted(true)\n   148→        setEmail('')\n   149→        setPhone('')\n   150→      } else {\n   151→        setError('Something went wrong. Please try again.')\n   152→      }\n   153→    } catch (err) {\n   154→      setError('Network error. Please try again.')\n   155→      console.error(err)\n   156→    } finally {\n