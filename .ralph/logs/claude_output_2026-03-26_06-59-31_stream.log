font-family: 'Sora', sans-serif;\n  font-size: 12px;\n  color: rgba(240,234,214,0.5);\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  margin: 0;\n}\n\n.ctas { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }\n\n.primaryCta {\n  background: #ff4d1c;\n  color: #110d06;\n  padding: 16px 36px;\n  border-radius: 100px;\n  font-size: 1rem;\n  font-weight: 700;\n  transition: all 0.2s;\n}\n.primaryCta:hover { background: #ff7043; transform: translateY(-2px); }\n\n.secondaryCta {\n  background: rgba(255,200,120,0.06);\n  border: 1px solid rgba(255,200,120,0.15);\n  color: rgba(240,234,214,0.7);\n  padding: 16px 36px;\n  border-radius: 100px;\n  font-size: 1rem;\n  font-weight: 500;\n  transition: all 0.2s;\n}\n.secondaryCta:hover {\n  border-color: rgba(255,77,28,0.3);\n  color: #f0ead6;\n}\n\n/* Confirmation Screen */\n.confirmation {\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: #211A14;\n  padding: 24px;\n}\n\n.confirmationContent {\n  text-align: center;\n  max-width: 400px;\n}\n\n.confirmationMark {\n  font-size: 48px;\n  margin-bottom: 16px;\n}\n\n.confirmationHeadline {\n  font-family: 'Sora', sans-serif;\n  font-size: 24px;\n  font-weight: 600;\n  color: #F5F0E3;\n  margin: 0 0 8px 0;\n}\n\n.confirmationSub {\n  font-family: 'Figtree', sans-serif;\n  font-size: 13px;\n  color: rgba(240,234,214,0.6);\n  margin: 0 0 20px 0;\n  line-height: 1.5;\n}\n\n.confirmationDivider {\n  height: 1px;\n  background: rgba(240,234,214,0.1);\n  margin: 20px 0;\n}\n\n.confirmationRows {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.confirmationRow {\n  font-family: 'Figtree', sans-serif;\n  font-size: 12px;\n  color: rgba(240,234,214,0.5);\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  justify-content: center;\n}\n\n.confirmationCheck {\n  color: #FF6644;\n  font-weight: 700;\n}\n\n/* Features Section */\n.featuresSection {\n  background: #211A14;\n  padding: 80px 24px;\n  border-top: 1px solid rgba(240,234,214,0.08);\n}\n\n.featuresContainer {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.sectionTitle {\n  font-family: 'Sora', sans-serif;\n  font-size: 28px;\n  font-weight: 600;\n  color: #F5F0E3;\n  text-align: center;\n  margin: 0 0 48px 0;\n}\n\n.featuresList {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n  gap: 32px;\n}\n\n.featureCard {\n  padding: 0;\n}\n\n.featureTitle {\n  font-family: 'Figtree', sans-serif;\n  font-size: 16px;\n  font-weight: 700;\n  color: #F5F0E3;\n  margin: 0 0 12px 0;\n}\n\n.featureDesc {\n  font-family: 'Figtree', sans-serif;\n  font-size: 14px;\n  color: rgba(240,234,214,0.65);\n  line-height: 1.6;\n  margin: 0;\n}\n\n/* Social Proof Section */\n.socialProofSection {\n  background: #211A14;\n  padding: 60px 24px;\n  border-top: 1px solid rgba(240,234,214,0.08);\n}\n\n.socialProofCard {\n  background: #3E3228;\n  border-left: 4px solid #FF6644;\n  border-radius: 12px;\n  padding: 32px;\n  max-width: 600px;\n  margin: 0 auto;\n  text-align: center;\n}\n\n.socialProofTitle {\n  font-family: 'Figtree', sans-serif;\n  font-size: 16px;\n  font-weight: 700;\n  color: #F5F0E3;\n  margin: 0 0 12px 0;\n}\n\n.socialProofSub {\n  font-family: 'Figtree', sans-serif;\n  font-size: 13px;\n  color: rgba(240,234,214,0.5);\n  margin: 0;\n  line-height: 1.6;\n}\n","numLines":247,"startLine":100,"totalLines":346}}}
