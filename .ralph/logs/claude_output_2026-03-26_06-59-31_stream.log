 { display: flex; align-items: center; gap: 12px; }\n\n.loginLink {\n  padding: 10px 20px;\n  color: rgba(240,234,214,0.65);\n  font-size: 0.9rem;\n  font-weight: 500;\n  transition: color 0.2s;\n}\n.loginLink:hover { color: #f0ead6; }\n\n.signupLink {\n  background: #ff4d1c;\n  color: #110d06;\n  padding: 10px 24px;\n  border-radius: 100px;\n  font-size: 0.9rem;\n  font-weight: 700;\n  transition: all 0.2s;\n}\n.signupLink:hover { background: #ff7043; transform: translateY(-1px); }\n\n/* Keyframes for animated mark */\n@keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }\n\n.layer1 { animation: fadeIn 0.4s ease-out 0.1s forwards; opacity: 0; }\n.layer2 { animation: fadeIn 0.4s ease-out 0.2s forwards; opacity: 0; }\n.layer3 { animation: fadeIn 0.4s ease-out 0.3s forwards; opacity: 0; }\n.layer4 { animation: fadeIn 0.4s ease-out 0.4s forwards; opacity: 0; }\n.layer5 { animation: fadeIn 0.4s ease-out 0.5s forwards; opacity: 0; }\n.layer6 { animation: fadeIn 0.4s ease-out 0.6s forwards; opacity: 0; }\n.layer7 { animation: fadeIn 0.4s ease-out 0.7s forwards; opacity: 0; }\n.layer8 { animation: fadeIn 0.4s ease-out 0.8s forwards; opacity: 0; }\n.layer9 { animation: fadeIn 0.4s ease-out 0.9s forwards; opacity: 0; }\n\n.animatedMark {\n  margin-bottom: 28px;\n}\n\n.hero {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  padding: 60px 24px;\n  background: #211A14;\n}\n\n.heroContent {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  max-width: 600px;\n}\n\n.badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  background: rgba(255,102,68,0.1);\n  border: 1px solid rgba(255,102,68,0.25);\n  color: #FF6644;\n  font-size: 0.78rem;\n  font-weight: 600;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  padding: 8px 18px;\n  border-radius: 100px;\n  margin-bottom: 32px;\n}\n\n.headline {\n  font-family: 'Sora', sans-serif;\n  font-weight: 600;\n  font-size: clamp(1.8rem, 5vw, 2.8rem);\n  line-height: 1.2;\n  letter-spacing: -0.01em;\n  color: #F5F0E3;\n  max-width: 600px;\n  margin-bottom: 16px;\n}\n\n.sub {\n  font-family: 'Figtree', sans-serif;\n  font-size: 1rem;\n  color: rgba(240,234,214,0.7);\n  font-weight: 400;","numLines":100,"startLine":1,"totalLines":346}}}
