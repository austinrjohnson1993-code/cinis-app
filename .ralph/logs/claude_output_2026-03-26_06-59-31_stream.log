2s ease;\n   400→          }\n   401→          .input::placeholder { color: rgba(240, 234, 214, 0.4); }\n   402→          .input:focus {\n   403→            outline: none;\n   404→            border-color: rgba(255, 102, 68, 0.4);\n   405→            background: rgba(58, 50, 40, 0.6);\n   406→          }\n   407→          .error {\n   408→            font-size: 12px;\n   409→            color: #FF5252;\n   410→            margin-top: -8px;\n   411→          }\n   412→          .button {\n   413→            font-family: 'Figtree', sans-serif;\n   414→            font-size: 14px;\n   415→            font-weight: 600;\n   416→            padding: 14px 20px;\n   417→            background: #FF6644;\n   418→            color: #F5F0E3;\n   419→            border: none;\n   420→            border-radius: 10px;\n   421→            cursor: pointer;\n   422→            transition: all 0.2s ease;\n   423→            text-transform: uppercase;\n   424→            letter-spacing: 0.05em;\n   425→            animation: ctaPulse 2s ease 3.5s infinite;\n   426→          }\n   427→          .button:hover:not(:disabled) {\n   428→            background: #FF7755;\n   429→            transform: translateY(-2px);\n   430→          }\n   431→          .button:disabled {\n   432→            opacity: 0.5;\n   433→            cursor: not-allowed;\n   434→          }\n   435→          .micro {\n   436→            font-family: 'Figtree', sans-serif;\n   437→            font-size: 11px;\n   438→            color: #F5F0E318;\n   439→            margin-top: 8px;\n   440→            opacity: 0;\n   441→            animation: fadeUp 0.4s ease-out forwards;\n   442→          }\n   443→          .confirmation {\n   444→            display: flex;\n   445→            flex-direction: column;\n   446→            align-items: center;\n   447→            justify-content: center;\n   448→            text-align: center;\n   449→            min-height: 100vh;\n   450→            padding: 24px;\n   451→            position: relative;\n   452→            z-index: 2;\n   453→          }\n   454→          .confirmation-mark {\n   455→            font-size: 48px;\n   456→            margin-bottom: 12px;\n   457→          }\n   458→          .confirmation-headline {\n   459→            font-family: 'Sora', sans-serif;\n   460→            font-size: 24px;\n   461→            font-weight: 600;\n   462→            color: #F5F0E3;\n   463→            margin-bottom: 8px;\n   464→          }\n   465→          .confirmation-sub {\n   466→            font-family: 'Figtree', sans-serif;\n   467→            font-size: 14px;\n   468→            color: rgba(240, 234, 214, 0.6);\n   469→            margin-bottom: 20px;\n   470→            line-height: 1.5;\n   471→          }\n   472→          .confirmation-divider {\n   473→            height: 1px;\n   474→            background: #F5F0E318;\n   475→            width: 100%;\n   476→            max-width: 300px;\n   477→            margin: 16px auto;\n   478→          }\n   479→          .confirmation-rows {\n   480→            display: flex;\n   481→            flex-direction: column;\n   482→            gap: 12px;\n   483→          }\n   484→          .confirmation-row {\n   485→            font-family: 'Figtree', sans-serif;\n   486→            font-size: 12px;\n   487→            color: #F5F0E350;\n   488→            display: flex;\n   489→            align-items: center;\n   490→            justify-content: center;\n   491→            gap: 10px;\n   492→          }\n   493→          .checkmark {\n   494→            color: #FF6644;\n   495→            font-weight: 700;\n   496→          }\n   497→          .reveal-section {\n   498→            opacity: 0;\n   499→            transform: translateY(28px);\n   500→            transition: none;\n   501→          }\n   502→          .reveal-section.revealed {\n   503→            animation: sectionReveal 0.6s ease forwards;\n   504→          }\n   505→          .section {\n   506→            padding: 100px 24px;\n   507→            position: relative;\n   508→            z-index: 2;\n   509→          }\n   510→          .problem-section {\n   511→            background: #1A130E;\n   512→            text-align: center;\n   513→          }\n   514→          .problem-eyebrow {\n   515→            color: #FF6644;\n   516→            font-family: 'Sora', sans-serif;\n   517→            font-size: 10px;\n   518→            font-weight: 600;\n   519→            letter-spacing: 0.2em;\n   520→            text-transform: uppercase;\n   521→            margin-bottom: 16px;\n   522→          }\n   523→          .problem-headline {\n   524→            font-family: 'Sora', sans-serif;\n   525→            font-size: 32px;\n   526→            font-weight: 600;\n   527→            color: #F5F0E3;\n   528→            margin-bottom: 20px;\n   529→            border-left: 3px solid #FF6644;\n   530→            padding-left: 20px;\n   531→            text-align: left;\n   532→            display: inline-block;\n   533→          }\n   534→          .problem-text {\n   535→            font-family: 'Figtree', sans-serif;\n   536→            font-size: 16px;\n   537→            color: rgba(240, 234, 214, 0.7);\n   538→            line-height: 1.85;\n   539→            max-width: 580px;\n   540→            margin: 0 auto;\n   541→            text-align: left;\n   542→          }\n   543→          .problem-text + .problem-text {\n   544→            margin-top: 12px;\n   545→          }\n   546→          .pillars-section {\n   547→            background: #211A14;\n   548→          }\n   549→          .pillars-eyebrow {\n   550→            color: #FF6644;\n   551→            font-family: 'Sora', sans-serif;\n   552→            font-size: 10px;\n   553→            font-weight: 600;\n   554→            letter-spacing: 0.2em;\n   555→            text-transform: uppercase;\n   556→            text-align: center;\n   557→            margin-bottom: 16px;\n   558→          }\n   559→          .pillars-headline {\n   560→            font-family: 'Sora', sans-serif;\n   561→            font-size: 32px;\n   562→            font-weight: 600;\n   563→            color: #F5F0E3;\n   564→            text-align: center;\n   565→            margin-bottom: 48px;\n   566→          }\n   567→          .pillars-grid {\n   568→            display: grid;\n   569→            grid-template-columns: repeat(3, 1fr);\n   570→            gap: 16px;\n   571→            max-width: 1000px;\n   572→            margin: 0 auto;\n   573→          }\n   574→          .pillar-card {\n   575→            background: #1A130E;\n   576→            border: 1px #F5F0E31E;\n   577→            border-style: solid;\n   578→            border-radius: 14px;\n   579→            border-top: 2px solid #FF6644;\n   580→            padding: 28px 24px;\n   581→            text-align: left;\n   582→          }\n   583→          .pillar-number {\n   584→            font-family: 'Sora', sans-serif;\n   585→            font-size: 11px;\n   586→            font-weight: 300;\n   587→            color: #F5F0E350;\n   588→            margin-bottom: 12px;\n   589→          }\n   590→          .pillar-title {\n   591→            font-family: 'Sora', sans-serif;\n   592→            font-size: 17px;\n   593→            font-weight: 600;\n   594→            color: #F5F0E3;\n   595→            margin-bottom: 10px;\n   596→          }\n   597→          .pillar-body {\n   598→            font-family: 'Figtree', sans-serif;\n   599→            font-size: 14px;\n   600→            color: rgba(240, 234, 214, 0.65);\n   601→            line-height: 1.8;\n   602→          }\n   603→          .proof-section {\n   604→            background: #1A130E;\n   605→            text-align: center;\n   606→          }\n   607→          .proof-headline {\n   608→            font-family: 'Sora', sans-serif;\n   609→            font-size: 28px;\n   610→            font-weight: 600;\n   611→            color: #F5F0E3;\n   612→            margin-bottom: 40px;\n   613→          }\n   614→          .proof-tiles {\n   615→            display: grid;\n   616→            grid-template-columns: repeat(3, 1fr);\n   617→            gap: 12px;\n   618→            max-width: 900px;\n   619→            margin: 0 auto;\n   620→          }\n   621→          .proof-tile {\n   622→            background: #211A14;\n   623→            border-radius: 12px;\n   624→            border: 1px #F5F0E31E;\n   625→            border-style: solid;\n   626→            padding: 24px 16px;\n   627→            text-align: center;\n   628→          }\n   629→          .proof-number {\n   630→            font-family: 'Sora', sans-serif;\n   631→            font-size: 28px;\n   632→            font-weight: 600;\n   633→            color: #FF6644;\n   634→            margin-bottom: 6px;\n   635→          }\n   636→          .proof-label {\n   637→            font-family: 'Figtree', sans-serif;\n   638→            font-size: 13px;\n   639→            font-weight: 500;\n   640→            color: #F5F0E3;\n   641→            margin-bottom: 6px;\n   642→          }\n   643→          .proof-desc {\n   644→            font-family: 'Figtree', sans-serif;\n   645→            font-size: 11px;\n   646→            color: rgba(240, 234, 214, 0.5);\n   647→            line-height: 1.6;\n   648→          }\n   649→          .cta-section {\n   650→            background: #211A14;\n   651→            text-align: center;\n   652→          }\n   653→          .cta-headline {\n   654→            font-family: 'Sora', sans-serif;\n   655→            font-size: 32px;\n   656→            font-weight: 600;\n   657→            color: #F5F0E3;\n   658→            margin-bottom: 12px;\n   659→          }\n   660→          .cta-subhead {\n   661→            font-family: 'Figtree', sans-serif;\n   662→            font-size: 15px;\n   663→            color: rgba(240, 234, 214, 0.7);\n   664→            margin-bottom: 32px;\n   665→          }\n   666→          .footer {\n   667→            background: #110C08;\n   668→            padding: 32px 24px;\n   669→            text-align: center;\n   670→            border-top: 0.5px solid #F5F0E318;\n   671→            position: relative;\n   672→            z-index: 2;\n   673→          }\n   674→          .footer-logo {\n   675→            display: flex;\n   676→            align-items: center;\n   677→            justify-content: center;\n   678→            gap: 6px;\n   679→            margin-bottom: 12px;\n   680→            font-family: 'Sora', sans-serif;\n   681→            font-weight: 600;\n   682→            font-size: 9px;\n   683→            letter-spacing: 0.16em;\n   684→            color: #F5F0E3;\n   685→          }\n   686→          .footer-tagline {\n   687→            font-family: 'Figtree', sans-serif;\n   688→            font-size: 11px;\n   689→            color: #F5F0E350;\n   690→            margin-bottom: 12px;\n   691→          }\n   692→          .footer-links {\n   693→            display: flex;\n   694→            align-items: center;\n   695→            justify-content: center;\n   696→            gap: 16px;\n   697→            margin-bottom: 16px;\n   698→            font-size: 10px;\n   699→          }\n   700→          .footer-link {\n   701→            color: #F5F0E350;\n   702→            text-decoration: none;\n   703→            transition: color 0.2s;\n   704→          }\n   705→          .footer-link:hover { color: #F5F0E3; }\n   706→          .footer-micro {\n   707→            font-family: 'Figtree', sans-serif;\n   708→            font-size: 9px;\n   709→            color: #F5F0E318;\n   710→            margin-top: 16px;\n   711→          }\n   712→          @media (max-width: 640px) {\n   713→            .nav { padding: 16px 20px; }\n   714→            .hero { padding: 64px 20px 48px; }\n   715→            .headline { font-size: 34px; }\n   716→            .pillars-grid { grid-template-columns: 1fr; }\n   717→            .proof-tiles { grid-template-columns: 1fr; }\n   718→            .section { padding: 64px 20px; }\n   719→            .problem-headline { font-size: 28px; }\n   720→            .pillars-headline { font-size: 28px; }\n   721→            .proof-headline { font-size: 24px; }\n   722→            .cta-headline { font-size: 28px; }\n   723→          }\n   724→        `}</style>\n   725→      </Head>\n   726→\n   727→      <div className=\"page\">\n   728→        <div id=\"cursor-glow\" />\n   729→        <div id=\"grain-overlay\" />\n   730→\n   731→        {/* NAV */}\n   732→        <nav className=\"nav\">\n   733→          <span className=\"nav-logo\">\n   734→            <svg width=\"20\" height=\"20\" viewBox=\"0 0 64 64\" fill=\"none\" style={{ flexShrink: 0 }}>\n   735→              <polygon points=\"32,4 54,16 54,42 32,54 10,42 10,16\" fill=\"#FF6644\"/>\n   736→              <polygon points=\"32,7 51,18 51,40 32,52 13,40 13,18\" fill=\"#120704\"/>\n   737→            </svg>\n   738→            CINIS\n   739→          </span>\n   740→          <div className=\"nav-links\">\n   741→            <a href=\"/login\" className=\"nav-link\">Sign in</a>\n   742→            <button onClick={() => router.push('/signup')} className=\"nav-cta\">Get started</button>\n   743→          </div>\n   744→        </nav>\n   745→\n   746→        {/* HERO */}\n   747→        {formSubmitted ? (\n   748→          <div className=\"hero confirmation\">\n   749→            <div style={{ maxWidth: 400 }}>\n   750→              <div className=\"confirmation-mark\">🔥</div>\n   751→              <h2 className=\"confirmation-headline\">You're on the list.</h2>\n   752→              <p className=\"confirmation-sub\">We launch April 14. You'll hear from us that morning.</p>\n   753→              <div className=\"confirmation-divider\" />\n   754→              <div className=\"confirmation-rows\">\n   755→                <div className=\"confirmation-row\"><span className=\"checkmark\">✓</span> Early access confirmed</div>\n   756→                <div className=\"confirmation-row\"><span className=\"checkmark\">✓</span> Launch-day pricing locked</div>\n   757→                <div className=\"confirmation-row\"><span className=\"checkmark\">✓</span> We'll never send you spam</div>\n   758→              </div>\n   759→            </div>\n   760→          </div>\n   761→        ) : (\n   762→          <div className=\"hero\">\n   763→            <div style={{\n   764→              animation: phase >= 1 ? 'markForge 0.8s ease-out forwards' : 'none',\n   765→              marginBottom: 28,\n   766→              display: 'flex',\n   767→              alignItems: 'center',\n   768→              justifyContent: 'center'\n   769→            }}>\n   770→              <AnimatedMark phase={phase >= 2} />\n   771→            </div>\n   772→            {phase >= 4 && <EmberParticles ready={true} />}\n   773→\n   774→            <div style={{\n   775→              fontFamily: \"'Sora', sans-serif\",\n   776→              fontSize: 30,\n   777→              fontWeight: 600,\n   778→              letterSpacing: '0.16em',\n   779→              color: '#F5F0E3',\n   780→              marginBottom: 24,\n   781→              opacity: phase >= 4 ? 1 : 0,\n   782→              animation: phase >= 4 ? 'wordSlice 0.6s ease-out forwards' : 'none'\n   783→            }}>\n   784→              CINIS\n   785→            </div>\n   786→\n   787→            <div className=\"eyebrow\" style={{ animation: phase >= 5 ? 'fadeUp 0.5s ease-out forwards' : 'none' }}>\n   788→              EARLY ACCESS\n   789→            </div>\n   790→\n   791→            <h2 className=\"headline\" style={{ animation: phase >= 5 ? 'fadeUp 0.5s ease-out forwards' : 'none' }}>\n   792→              The part of your brain<br />that keeps you on track.\n   793→            </h2>\n   794→\n   795→            <p className=\"subhead\" style={{ animation: phase >= 6 ? 'fadeUp 0.5s ease-out forwards' : 'none' }}>\n   796→              Cinis learns how you work, reaches out before you fall behind, and remembers everything — so you don't have to.\n   797→            </p>\n   798→\n   799→            <form onSubmit={handleSubmit} className=\"form\" style={{ animation: phase >= 7 ? 'slideUp 0.4s ease-out forwards' : 'none' }}>\n   800→              <input type=\"tel\" placeholder=\"+1 (555) 000-0000\" value={phone} onChange={(e) => setPhone(e.target.value)} className=\"input\" />\n   801→              <input type=\"email\" placeholder=\"you@example.com\" value={email} onChange={(e) => setEmail(e.target.value)} className=\"input\" required />\n   802→              {error && <span className=\"error\">{error}</span>}\n   803→              <button type=\"submit\" disabled={loading || !email.includes('@')} className=\"button\">\n   804→                {loading ? 'Joining...' : 'Get early access'}\n   805→              </button>\n   806→            </form>\n   807→            <p className=\"micro\" style={{ animation: phase >= 7 ? 'fadeUp 0.4s ease-out forwards' : 'none' }}>Free to start. No credit card.</p>\n   808→          </div>\n   809→        )}\n   810→\n   811→        {/* THE PROBLEM */}\n   812→        <section className=\"section problem-section reveal-section\" ref={(el) => { revealRefs.current.problem = el }}>\n   813→          <div style={{ maxWidth: 580, margin: '0 auto', textAlign: 'center' }}>\n   814→            <div className=\"problem-eyebrow\">THE PROBLEM</div>\n   815→            <div className=\"problem-headline\">You're not lazy. You're not broken.</div>\n   816→            <p className=\"problem-text\">The gap between knowing what to do and actually doing it is real. For a lot of people, it's wider than for others — and no amount of motivation or better apps has closed it.</p>\n   817→            <p className=\"problem-text\">Cinis doesn't try to motivate you. It doesn't send you another push notification you'll ignore. It builds a picture of how you actually work, then keeps you moving — quietly, specifically, in the background.</p>\n   818→          </div>\n   819→        </section>\n   820→\n   821→        {/* THREE PILLARS */}\n   822→        <section className=\"section pillars-section reveal-section\" ref={(el) => { revealRefs.current.pillars = el }}>\n   823→          <div className=\"pillars-eyebrow\">HOW IT WORKS</div>\n   824→          <h2 className=\"pillars-headline\">Three things no other app does</h2>\n   825→          <div className=\"pillars-grid\">\n   826→            <div className=\"pillar-card\">\n   827→              <div className=\"pillar-number\">01</div>\n   828→              <div className=\"pillar-title\">It learns you</div>\n   829→              <p className=\"pillar-body\">Answer 13 questions once. Cinis builds a coaching profile around your specific patterns — what stalls you, what moves you, what time of day you actually function. Every interaction gets smarter from there.</p>\n   830→            </div>\n   831→            <div className=\"pillar-card\">\n   832→              <div className=\"pillar-number\">02</div>\n   833→              <div className=\"pillar-title\">It reaches out</div>\n   834→              <p className=\"pillar-body\">You don't open Cinis. Cinis opens you. Morning check-ins, evening wrap-ups, nudges when you've gone quiet. It shows up — before you've had a chance to forget.</p>\n   835→            </div>\n   836→            <div className=\"pillar-card\">\n   837→              <div className=\"pillar-number\">03</div>\n   838→              <div className=\"pillar-title\">It remembers</div>\n   839→              <p className=\"pillar-body\">What you told it last week. What you avoided. What actually worked. The longer you use it, the more it knows — and the less you have to explain yourself every time.</p>\n   840→            </div>\n   841→          </div>\n   842→        </section>\n   843→\n   844→        {/* PROOF POINTS */}\n   845→        <section className=\"section proof-section reveal-section\" ref={(el) => { revealRefs.current.proof = el }}>\n   846→          <h2 className=\"proof-headline\">Built for the way your brain actually works.</h2>\n   847→          <div className=\"proof-tiles\">\n   848→            <div className=\"proof-tile\">\n   849→              <div className=\"proof-number\">13</div>\n   850→              <div className=\"proof-label\">Questions</div>\n   851→              <p className=\"proof-desc\">Your coach knows you before you send a single message</p>\n   852→            </div>\n   853→            <div className=\"proof-tile\">\n   854→              <div className=\"proof-number\">6</div>\n   855→              <div className=\"proof-label\">Coaching voices</div>\n   856→              <p className=\"proof-desc\">Find the tone that actually moves you</p>\n   857→            </div>\n   858→            <div className=\"proof-tile\">\n   859→              <div className=\"proof-number\">3-layer</div>\n   860→              <div className=\"proof-label\">Memory</div>\n   861→              <p className=\"proof-desc\">Remembers yesterday, last week, and who you are</p>\n   862→            </div>\n   863→          </div>\n   864→        </section>\n   865→\n   866→        {/* BOTTOM CTA */}\n   867→        <section className=\"section cta-section reveal-section\" ref={(el) => { revealRefs.current.cta = el }}>\n   868→          <h2 className=\"cta-headline\">Ready for something that actually shows up?</h2>\n   869→          <p className=\"cta-subhead\">Join free. No credit card. Cancel whenever.</p>\n   870→          <form onSubmit={handleSubmit} className=\"form\" style={{ maxWidth: 340, margin: '0 auto 12px' }}>\n   871→            <input type=\"tel\" placeholder=\"+1 (555) 000-0000\" value={phone} onChange={(e) => setPhone(e.target.value)} className=\"input\" />\n   872→            <input type=\"email\" placeholder=\"you@example.com\" value={email} onChange={(e) => setEmail(e.target.value)} className=\"input\" required />\n   873→            {error && <span className=\"error\">{error}</span>}\n   874→            <button type=\"submit\" disabled={loading || !email.includes('@')} className=\"button\">\n   875→              {loading ? 'Joining...' : 'Get early access'}\n   876→            </button>\n   877→          </form>\n   878→          <p className=\"micro\" style={{ opacity: 1, animation: 'none', marginTop: 0 }}>Free to start. No credit card.</p>\n   879→        </section>\n   880→\n   881→        {/* FOOTER */}\n   882→        <footer className=\"footer\">\n   883→          <div className=\"footer-logo\">\n   884→            <svg width=\"14\" height=\"14\" viewBox=\"0 0 64 64\" fill=\"none\">\n   885→              <polygon points=\"32,4 54,16 54,42 32,54 10,42 10,16\" fill=\"#FF6644\"/>\n   886→              <polygon points=\"32,7 51,18 51,40 32,52 13,40 13,18\" fill=\"#120704\"/>\n   887→            </svg>\n   888→            CINIS\n   889→          </div>\n   890→          <p className=\"footer-tagline\">Where start meets finished.</p>\n   891→          <div className=\"footer-links\">\n   892→            <a href=\"https://twitter.com\" className=\"footer-link\">Twitter</a>\n   893→            <a href=\"https://instagram.com\" className=\"footer-link\">Instagram</a>\n   894→            <a href=\"/privacy\" className=\"footer-link\">Privacy</a>\n   895→          </div>\n   896→          <p className=\"footer-micro\">Cinis · Early Access 2026</p>\n   897→        </footer>\n   898→      </div>\n   899→    </>\n   900→  )\n   901→}\n   902→"}]},"parent_tool_use_id":null,"session_id":"77163ddc-e56f-40e1-922e-2ae866d202b1","uuid":"d6330457-7952-468f-bb73-935a3a551d71","timestamp":"2026-03-26T12:00:06.109Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/index.js","content":"            color: #F5F0E3;\n          }\n          .nav-links {\n            display: flex;\n            align-items: center;\n            gap: 12px;\n          }\n          .nav-link {\n            color: rgba(240, 234, 214, 0.65);\n            text-decoration: none;\n            font-size: 0.9rem;\n            font-weight: 500;\n            transition: color 0.2s;\n            padding: 10px 20px;\n          }\n          .nav-link:hover { color: #F5F0E3; }\n          .nav-cta {\n            background: #FF6644;\n            color: #110d06;\n            padding: 10px 24px;\n            border-radius: 100px;\n            font-weight: 700;\n            text-decoration: none;\n            font-size: 0.9rem;\n            transition: all 0.2s;\n            cursor: pointer;\n            border: none;\n            font-family: 'Figtree', sans-serif;\n          }\n          .nav-cta:hover { background: #FF7755; transform: translateY(-1px); }\n          .hero {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            text-align: center;\n            min-height: 100vh;\n            padding: 100px 24px 60px;\n            background: #211A14;\n            position: relative;\n            z-index: 2;\n          }\n          .eyebrow {\n            font-family: 'Sora', sans-serif;\n            font-size: 10px;\n            font-weight: 600;\n            letter-spacing: 0.2em;\n            text-transform: uppercase;\n            color: #FF6644;\n            margin-bottom: 24px;\n            opacity: 0;\n            animation: fadeUp 0.5s ease-out forwards;\n          }\n          .headline {\n            font-family: 'Sora', sans-serif;\n            font-weight: 600;\n            font-size: 52px;\n            color: #F5F0E3;\n            line-height: 1.1;\n            margin-bottom: 16px;\n            max-width: 640px;\n            opacity: 0;\n            animation: fadeUp 0.5s ease-out forwards;\n            overflow: hidden;\n          }\n          .headline-line {\n            clip-path: inset(0 100% 0 0);\n          }\n          .headline-line.active {\n            animation: textReveal 0.5s ease-out forwards;\n          }\n          .subhead {\n            font-family: 'Figtree', sans-serif;\n            font-size: 16px;\n            color: #F5F0E390;\n            line-height: 1.7;\n            max-width: 480px;\n            margin-bottom: 32px;\n            opacity: 0;\n            animation: fadeUp 0.5s ease-out forwards;\n          }\n          .form {\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n            width: 100%;\n            max-width: 340px;\n            opacity: 0;\n            animation: slideUp 0.4s ease-out forwards;\n          }\n          .input {\n            font-family: 'Figtree', sans-serif;\n            font-size: 14px;\n            padding: 14px 16px;\n            border: 1px #F5F0E31E;\n            border-style: solid;\n            border-radius: 10px;\n            background: rgba(58, 50, 40, 0.4);\n            color: #F5F0E3;\n            transition: all 0.2s ease;\n          }\n          .input::placeholder { color: rgba(240, 234, 214, 0.4); }\n          .input:focus {\n            outline: none;\n            border-color: rgba(255, 102, 68, 0.4);\n            background: rgba(58, 50, 40, 0.6);\n          }\n          .error {\n            font-size: 12px;\n            color: #FF5252;\n            margin-top: -8px;\n          }\n          .button {\n            font-family: 'Figtree', sans-serif;\n            font-size: 14px;\n            font-weight: 600;\n            padding: 14px 20px;\n            background: #FF6644;\n            color: #F5F0E3;\n            border: none;\n            border-radius: 10px;\n            cursor: pointer;\n            transition: all 0.2s ease;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n            animation: ctaPulse 2s ease 3.5s infinite;\n          }\n          .button:hover:not(:disabled) {\n            background: #FF7755;\n            transform: translateY(-2px);\n          }\n          .button:disabled {\n            opacity: 0.5;\n            cursor: not-allowed;\n          }\n          .micro {\n            font-family: 'Figtree', sans-serif;\n            font-size: 11px;\n            color: #F5F0E318;\n            margin-top: 8px;\n            opacity: 0;\n            animation: fadeUp 0.4s ease-out forwards;\n          }\n          .confirmation {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            text-align: center;\n            min-height: 100vh;\n            padding: 24px;\n            position: relative;\n            z-index: 2;\n          }\n          .confirmation-mark {\n            font-size: 48px;\n            margin-bottom: 12px;\n          }\n          .confirmation-headline {\n            font-family: 'Sora', sans-serif;\n            font-size: 24px;\n            font-weight: 600;\n            color: #F5F0E3;\n            margin-bottom: 8px;\n          }\n          .confirmation-sub {\n            font-family: 'Figtree', sans-serif;\n            font-size: 14px;\n            color: rgba(240, 234, 214, 0.6);\n            margin-bottom: 20px;\n            line-height: 1.5;\n          }\n          .confirmation-divider {\n            height: 1px;\n            background: #F5F0E318;\n            width: 100%;\n            max-width: 300px;\n            margin: 16px auto;\n          }\n          .confirmation-rows {\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n          }\n          .confirmation-row {\n            font-family: 'Figtree', sans-serif;\n            font-size: 12px;\n            color: #F5F0E350;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 10px;\n          }\n          .checkmark {\n            color: #FF6644;\n            font-weight: 700;\n          }\n          .reveal-section {\n            opacity: 0;\n            transform: translateY(28px);\n            transition: none;\n          }\n          .reveal-section.revealed {\n            animation: sectionReveal 0.6s ease forwards;\n          }\n          .section {\n            padding: 100px 24px;\n            position: relative;\n            z-index: 2;\n          }\n          .problem-section {\n            background: #1A130E;\n            text-align: center;\n          }\n          .problem-eyebrow {\n            color: #FF6644;\n            font-family: 'Sora', sans-serif;\n            font-size: 10px;\n            font-weight: 600;\n            letter-spacing: 0.2em;\n            text-transform: uppercase;\n            margin-bottom: 16px;\n          }\n          .problem-headline {\n            font-family: 'Sora', sans-serif;\n            font-size: 32px;\n            font-weight: 600;\n            color: #F5F0E3;\n            margin-bottom: 20px;\n            border-left: 3px solid #FF6644;\n            padding-left: 20px;\n            text-align: left;\n            display: inline-block;\n          }\n          .problem-text {\n            font-family: 'Figtree', sans-serif;\n            font-size: 16px;\n            color: rgba(240, 234, 214, 0.7);\n            line-height: 1.85;\n            max-width: 580px;\n            margin: 0 auto;\n            text-align: left;\n          }\n          .problem-text + .problem-text {\n            margin-top: 12px;\n          }\n          .pillars-section {\n            background: #211A14;\n          }\n          .pillars-eyebrow {\n            color: #FF6644;\n            font-family: 'Sora', sans-serif;\n            font-size: 10px;\n            font-weight: 600;\n            letter-spacing: 0.2em;\n            text-transform: uppercase;\n            text-align: center;\n            margin-bottom: 16px;\n          }\n          .pillars-headline {\n            font-family: 'Sora', sans-serif;\n            font-size: 32px;\n            font-weight: 600;\n            color: #F5F0E3;\n            text-align: center;\n            margin-bottom: 48px;\n          }\n          .pillars-grid {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 16px;\n            max-width: 1000px;\n            margin: 0 auto;\n          }\n          .pillar-card {\n            background: #1A130E;\n            border: 1px #F5F0E31E;\n            border-style: solid;\n            border-radius: 14px;\n            border-top: 2px solid #FF6644;\n            padding: 28px 24px;\n            text-align: left;\n          }\n          .pillar-number {\n            font-family: 'Sora', sans-serif;\n            font-size: 11px;\n            font-weight: 300;\n            color: #F5F0E350;\n            margin-bottom: 12px;\n          }\n          .pillar-title {\n            font-family: 'Sora', sans-serif;\n            font-size: 17px;\n            font-weight: 600;\n            color: #F5F0E3;\n            margin-bottom: 10px;\n          }\n          .pillar-body {\n            font-family: 'Figtree', sans-serif;\n            font-size: 14px;\n            color: rgba(240, 234, 214, 0.65);\n            line-height: 1.8;\n          }\n          .proof-section {\n            background: #1A130E;\n            text-align: center;\n          }\n          .proof-headline {\n            font-family: 'Sora', sans-serif;\n            font-size: 28px;\n            font-weight: 600;\n            color: #F5F0E3;\n            margin-bottom: 40px;\n          }\n          .proof-tiles {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 12px;\n            max-width: 900px;\n            margin: 0 auto;\n          }\n          .proof-tile {\n            background: #211A14;\n            border-radius: 12px;\n            border: 1px #F5F0E31E;\n            border-style: solid;\n            padding: 24px 16px;\n            text-align: center;\n          }\n          .proof-number {\n            font-family: 'Sora', sans-serif;\n            font-size: 28px;\n            font-weight: 600;\n            color: #FF6644;\n            margin-bottom: 6px;\n          }\n          .proof-label {\n            font-family: 'Figtree', sans-serif;\n            font-size: 13px;\n            font-weight: 500;\n            color: #F5F0E3;\n            margin-bottom: 6px;\n          }\n          .proof-desc {\n            font-family: 'Figtree', sans-serif;\n            font-size: 11px;\n            color: rgba(240, 234, 214, 0.5);\n            line-height: 1.6;\n          }\n          .cta-section {\n            background: #211A14;\n            text-align: center;\n          }\n          .cta-headline {\n            font-family: 'Sora', sans-serif;\n            font-size: 32px;\n            font-weight: 600;\n            color: #F5F0E3;\n            margin-bottom: 12px;\n          }\n          .cta-subhead {\n            font-family: 'Figtree', sans-serif;\n            font-size: 15px;\n            color: rgba(240, 234, 214, 0.7);\n            margin-bottom: 32px;\n          }\n          .footer {\n            background: #110C08;\n            padding: 32px 24px;\n            text-align: center;\n            border-top: 0.5px solid #F5F0E318;\n            position: relative;\n            z-index: 2;\n          }\n          .footer-logo {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            margin-bottom: 12px;\n            font-family: 'Sora', sans-serif;\n            font-weight: 600;\n            font-size: 9px;\n            letter-spacing: 0.16em;\n            color: #F5F0E3;\n          }\n          .footer-tagline {\n            font-family: 'Figtree', sans-serif;\n            font-size: 11px;\n            color: #F5F0E350;\n            margin-bottom: 12px;\n          }\n          .footer-links {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 16px;\n            margin-bottom: 16px;\n            font-size: 10px;\n          }\n          .footer-link {\n            color: #F5F0E350;\n            text-decoration: none;\n            transition: color 0.2s;\n          }\n          .footer-link:hover { color: #F5F0E3; }\n          .footer-micro {\n            font-family: 'Figtree', sans-serif;\n            font-size: 9px;\n            color: #F5F0E318;\n            margin-top: 16px;\n          }\n          @media (max-width: 640px) {\n            .nav { padding: 16px 20px; }\n            .hero { padding: 64px 20px 48px; }\n            .headline { font-size: 34px; }\n            .pillars-grid { grid-template-columns: 1fr; }\n            .proof-tiles { grid-template-columns: 1fr; }\n            .section { padding: 64px 20px; }\n            .problem-headline { font-size: 28px; }\n            .pillars-headline { font-size: 28px; }\n            .proof-headline { font-size: 24px; }\n            .cta-headline { font-size: 28px; }\n          }\n        `}</style>\n      </Head>\n\n      <div className=\"page\">\n        <div id=\"cursor-glow\" />\n        <div id=\"grain-overlay\" />\n\n        {/* NAV */}\n        <nav className=\"nav\">\n          <span className=\"nav-logo\">\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 64 64\" fill=\"none\" style={{ flexShrink: 0 }}>\n              <polygon points=\"32,4 54,16 54,42 32,54 10,42 10,16\" fill=\"#FF6644\"/>\n              <polygon points=\"32,7 51,18 51,40 32,52 13,40 13,18\" fill=\"#120704\"/>\n            </svg>\n            CINIS\n          </span>\n          <div className=\"nav-links\">\n            <a href=\"/login\" className=\"nav-link\">Sign in</a>\n            <button onClick={() => router.push('/signup')} className=\"nav-cta\">Get started</button>\n          </div>\n        </nav>\n\n        {/* HERO */}\n        {formSubmitted ? (\n          <div className=\"hero confirmation\">\n            <div style={{ maxWidth: 400 }}>\n              <div className=\"confirmation-mark\">🔥</div>\n              <h2 className=\"confirmation-headline\">You're on the list.</h2>\n              <p className=\"confirmation-sub\">We launch April 14. You'll hear from us that morning.</p>\n              <div className=\"confirmation-divider\" />\n              <div className=\"confirmation-rows\">\n                <div className=\"confirmation-row\"><span className=\"checkmark\">✓</span> Early access confirmed</div>\n                <div className=\"confirmation-row\"><span className=\"checkmark\">✓</span> Launch-day pricing locked</div>\n                <div className=\"confirmation-row\"><span className=\"checkmark\">✓</span> We'll never send you spam</div>\n              </div>\n            </div>\n          </div>\n        ) : (\n          <div className=\"hero\">\n            <div style={{\n              animation: phase >= 1 ? 'markForge 0.8s ease-out forwards' : 'none',\n              marginBottom: 28,\n              display: 'flex',\n              alignItems: 'center',\n              justifyContent: 'center'\n            }}>\n              <AnimatedMark phase={phase >= 2} />\n            </div>\n            {phase >= 4 && <EmberParticles ready={true} />}\n\n            <div style={{\n              fontFamily: \"'Sora', sans-serif\",\n              fontSize: 30,\n              fontWeight: 600,\n              letterSpacing: '0.16em',\n              color: '#F5F0E3',\n              marginBottom: 24,\n              opacity: phase >= 4 ? 1 : 0,\n              animation: phase >= 4 ? 'wordSlice 0.6s ease-out forwards' : 'none'\n            }}>\n              CINIS\n            </div>\n\n            <div className=\"eyebrow\" style={{ animation: phase >= 5 ? 'fadeUp 0.5s ease-out forwards' : 'none' }}>\n              EARLY ACCESS\n            </div>\n\n            <h2 className=\"headline\" style={{ animation: phase >= 5 ? 'fadeUp 0.5s ease-out forwards' : 'none' }}>\n              The part of your brain<br />that keeps you on track.\n            </h2>\n\n            <p className=\"subhead\" style={{ animation: phase >= 6 ? 'fadeUp 0.5s ease-out forwards' : 'none' }}>\n              Cinis learns how you work, reaches out before you fall behind, and remembers everything — so you don't have to.\n            </p>\n\n            <form onSubmit={handleSubmit} className=\"form\" style={{ animation: phase >= 7 ? 'slideUp 0.4s ease-out forwards' : 'none' }}>\n              <input type=\"tel\" placeholder=\"+1 (555) 000-0000\" value={phone} onChange={(e) => setPhone(e.target.value)} className=\"input\" />\n              <input type=\"email\" placeholder=\"you@example.com\" value={email} onChange={(e) => setEmail(e.target.value)} className=\"input\" required />\n              {error && <span className=\"error\">{error}</span>}\n              <button type=\"submit\" disabled={loading || !email.includes('@')} className=\"button\">\n                {loading ? 'Joining...' : 'Get early access'}\n              </button>\n            </form>\n            <p className=\"micro\" style={{ animation: phase >= 7 ? 'fadeUp 0.4s ease-out forwards' : 'none' }}>Free to start. No credit card.</p>\n          </div>\n        )}\n\n        {/* THE PROBLEM */}\n        <section className=\"section problem-section reveal-section\" ref={(el) => { revealRefs.current.problem = el }}>\n          <div style={{ maxWidth: 580, margin: '0 auto', textAlign: 'center' }}>\n            <div className=\"problem-eyebrow\">THE PROBLEM</div>\n            <div className=\"problem-headline\">You're not lazy. You're not broken.</div>\n            <p className=\"problem-text\">The gap between knowing what to do and actually doing it is real. For a lot of people, it's wider than for others — and no amount of motivation or better apps has closed it.</p>\n            <p className=\"problem-text\">Cinis doesn't try to motivate you. It doesn't send you another push notification you'll ignore. It builds a picture of how you actually work, then keeps you moving — quietly, specifically, in the background.</p>\n          </div>\n        </section>\n\n        {/* THREE PILLARS */}\n        <section className=\"section pillars-section reveal-section\" ref={(el) => { revealRefs.current.pillars = el }}>\n          <div className=\"pillars-eyebrow\">HOW IT WORKS</div>\n          <h2 className=\"pillars-headline\">Three things no other app does</h2>\n          <div className=\"pillars-grid\">\n            <div className=\"pillar-card\">\n              <div className=\"pillar-number\">01</div>\n              <div className=\"pillar-title\">It learns you</div>\n              <p className=\"pillar-body\">Answer 13 questions once. Cinis builds a coaching profile around your specific patterns — what stalls you, what moves you, what time of day you actually function. Every interaction gets smarter from there.</p>\n            </div>\n            <div className=\"pillar-card\">\n              <div className=\"pillar-number\">02</div>\n              <div className=\"pillar-title\">It reaches out</div>\n              <p className=\"pillar-body\">You don't open Cinis. Cinis opens you. Morning check-ins, evening wrap-ups, nudges when you've gone quiet. It shows up — before you've had a chance to forget.</p>\n            </div>\n            <div className=\"pillar-card\">\n              <div className=\"pillar-number\">03</div>\n              <div className=\"pillar-title\">It remembers</div>\n              <p className=\"pillar-body\">What you told it last week. What you avoided. What actually worked. The longer you use it, the more it knows — and the less you have to explain yourself every time.</p>\n            </div>\n          </div>\n        </section>\n\n        {/* PROOF POINTS */}\n        <section className=\"section proof-section reveal-section\" ref={(el) => { revealRefs.current.proof = el }}>\n          <h2 className=\"proof-headline\">Built for the way your brain actually works.</h2>\n          <div className=\"proof-tiles\">\n            <div className=\"proof-tile\">\n              <div className=\"proof-number\">13</div>\n              <div className=\"proof-label\">Questions</div>\n              <p className=\"proof-desc\">Your coach knows you before you send a single message</p>\n            </div>\n            <div className=\"proof-tile\">\n              <div className=\"proof-number\">6</div>\n              <div className=\"proof-label\">Coaching voices</div>\n              <p className=\"proof-desc\">Find the tone that actually moves you</p>\n            </div>\n            <div className=\"proof-tile\">\n              <div className=\"proof-number\">3-layer</div>\n              <div className=\"proof-label\">Memory</div>\n              <p className=\"proof-desc\">Remembers yesterday, last week, and who you are</p>\n            </div>\n          </div>\n        </section>\n\n        {/* BOTTOM CTA */}\n        <section className=\"section cta-section reveal-section\" ref={(el) => { revealRefs.current.cta = el }}>\n          <h2 className=\"cta-headline\">Ready for something that actually shows up?</h2>\n          <p className=\"cta-subhead\">Join free. No credit card. Cancel whenever.</p>\n          <form onSubmit={handleSubmit} className=\"form\" style={{ maxWidth: 340, margin: '0 auto 12px' }}>\n            <input type=\"tel\" placeholder=\"+1 (555) 000-0000\" value={phone} onChange={(e) => setPhone(e.target.value)} className=\"input\" />\n            <input type=\"email\" placeholder=\"you@example.com\" value={email} onChange={(e) => setEmail(e.target.value)} className=\"input\" required />\n            {error && <span className=\"error\">{error}</span>}\n            <button type=\"submit\" disabled={loading || !email.includes('@')} className=\"button\">\n              {loading ? 'Joining...' : 'Get early access'}\n            </button>\n          </form>\n          <p className=\"micro\" style={{ opacity: 1, animation: 'none', marginTop: 0 }}>Free to start. No credit card.</p>\n        </section>\n\n        {/* FOOTER */}\n        <footer className=\"footer\">\n          <div className=\"footer-logo\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 64 64\" fill=\"none\">\n              <polygon points=\"32,4 54,16 54,42 32,54 10,42 10,16\" fill=\"#FF6644\"/>\n              <polygon points=\"32,7 51,18 51,40 32,52 13,40 13,18\" fill=\"#120704\"/>\n            </svg>\n            CINIS\n          </div>\n          <p className=\"footer-tagline\">Where start meets finished.</p>\n          <div className=\"footer-links\">\n            <a href=\"https://twitter.com\" className=\"footer-link\">Twitter</a>\n            <a href=\"https://instagram.com\" className=\"footer-link\">Instagram</a>\n            <a href=\"/privacy\" className=\"footer-link\">Privacy</a>\n          </div>\n          <p className=\"footer-micro\">Cinis · Early Access 2026</p>\n        </footer>\n      </div>\n    </>\n  )\n}\n","numLines":603,"startLine":300,"totalLines":902}}}
