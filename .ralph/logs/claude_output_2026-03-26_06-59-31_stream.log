gacy logo class (kept for safety) ── */\n.logo {\n  display: block;\n  font-size: 1.6rem;\n  margin-bottom: 40px;\n  text-decoration: none;\n}\n\n.heading {\n  font-family: 'Figtree', sans-serif;\n  font-weight: 700;\n  font-size: 1.75rem;\n  color: #F0EAD6;\n  letter-spacing: -0.02em;\n  margin-bottom: 8px;\n}\n\n.sub {\n  font-size: 0.95rem;\n  color: rgba(240,234,214,0.5);\n  margin-bottom: 32px;\n}\n\n.googleBtn {\n  width: 100%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  background: #F0EAD6;\n  color: #211A14;\n  border: none;\n  border-radius: 100px;\n  padding: 14px 24px;\n  font-size: 0.95rem;\n  font-weight: 600;\n  font-family: 'Figtree', sans-serif;\n  cursor: pointer;\n  transition: all 0.2s;\n  margin-bottom: 24px;\n}\n\n.googleBtn:hover {\n  background: #ffffff;\n  transform: translateY(-1px);\n}\n\n.divider {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 24px;\n}\n\n.divider::before,\n.divider::after {\n  content: '';\n  flex: 1;\n  height: 1px;\n  background: rgba(255,200,120,0.12);\n}\n\n.divider span {\n  font-size: 0.8rem;\n  color: rgba(240,234,214,0.35);\n  white-space: nowrap;\n  font-family: 'Figtree', sans-serif;\n}\n\n.form {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.input {\n  width: 100%;\n  background: rgba(255,200,120,0.04);\n  border: 1px solid rgba(255,200,120,0.12);\n  border-radius: 100px;\n  padding: 14px 20px;\n  color: #F0EAD6;\n  font-size: 0.95rem;\n  font-family: 'Figtree', sans-serif;\n  outline: none;\n  transition: border-color 0.2s, box-shadow 0.2s;\n  box-sizing: border-box;\n}\n\n.input::placeholder { color: rgba(240,234,214,0.3); }\n\n.input:focus {\n  border-color: rgba(255,102,68,0.5);\n  box-shadow: 0 0 0 3px rgba(255,102,68,0.12);\n}\n\n.submitBtn {\n  width: 100%;\n  background: #FF6644;\n  color: #211A14;\n  border: none;\n  border-radius: 100px;\n  padding: 14px 24px;\n  font-size: 0.95rem;\n  font-weight: 700;\n  font-family: 'Figtree', sans-serif;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.submitBtn:hover:not(:disabled) {\n  background: #ff7c55;\n  transform: translateY(-1px);\n}\n\n.submitBtn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.error {\n  background: rgba(232,50,26,0.08);\n  border: 1px solid rgba(232,50,26,0.28);\n  color: #E8321A;\n  border-radius: 10px;\n  padding: 12px 16px;\n  font-size: 0.88rem;\n  font-family: 'Figtree', sans-serif;\n  margin-bottom: 12px;\n}\n\n.success {\n  background: rgba(255,102,68,0.06);\n  border: 1px solid rgba(255,102,68,0.2);\n  border-radius: 16px;\n  padding: 28px 24px;\n  text-align: center;\n}\n\n.successIcon {\n  width: 48px;\n  height: 48px;\n  background: rgba(255,102,68,0.12);\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 1.2rem;\n  color: #FF6644;\n  margin: 0 auto 16px;\n}\n\n.success p {\n  font-size: 0.95rem;\n  color: rgba(240,234,214,0.8);\n  line-height: 1.6;\n  font-family: 'Figtree', sans-serif;\n}\n\n.success strong { color: #F0EAD6; }\n\n.successSub {\n  margin-top: 8px;\n  font-size: 0.85rem !important;\n  color: rgba(240,234,214,0.45) !important;\n}\n\n.signupLink {\n  text-align: center;\n  margin-top: 20px;\n  font-size: 0.88rem;\n  color: rgba(240,234,214,0.4);\n  font-family: 'Figtree', sans-serif;\n}\n\n.signupLink a {\n  color: #FF6644;\n  font-weight: 600;\n  text-decoration: none;\n}\n\n.signupLink a:hover { text-decoration: underline; }\n\n@media (max-width: 480px) {\n  .card { padding: 32px 24px; }\n}\n","numLines":249,"startLine":1,"totalLines":249}}}
