{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M2patPyvhDsdPQ4yYf69ZK","type":"tool_result","content":"    80→    try {\n    81→      const savedColor = localStorage.getItem('fb_accent_color')\n    82→      if (savedColor) {\n    83→        const theme = THEMES.find(t => t.id === savedColor) || THEMES.find(t => t.accent === savedColor)\n    84→        if (theme) applyTheme(theme)\n    85→        else applyAccentColor(savedColor)\n    86→      }\n    87→    } catch {}\n    88→  }, [])\n    89→\n    90→  useEffect(() => {\n    91→    const hour = new Date().getHours()\n    92→    if (hour < 12) setGreeting('Good morning')\n    93→    else if (hour < 17) setGreeting('Good afternoon')\n    94→    else setGreeting('Good evening')\n    95→  }, [])\n    96→\n    97→  const fetchProfile = async (userId) => {\n    98→    const { data } = await supabase.from('profiles').select('*').eq('id', userId).single()\n    99→    if (data) {\n   100→      setProfile(data)\n   101→      if (data.accent_color) {\n   102→        const savedTheme = THEMES.find(t => t.id === data.accent_color) || THEMES.find(t => t.accent === data.accent_color) || THEMES[0]\n   103→        applyTheme(savedTheme)\n   104→        setActiveTheme(savedTheme)\n   105→        if (typeof localStorage !== 'undefined') localStorage.setItem('fb_accent_color', savedTheme.id)\n   106→      }\n   107→    } else {\n   108→      router.push('/onboarding')\n   109→    }\n   110→  }\n   111→\n   112→  const fetchTasks = async (userId) => {\n   113→    try {\n   114→      const { data, error } = await supabase\n   115→        .from('tasks').select('*').eq('user_id', userId).eq('archived', false)\n   116→        .order('sort_order', { ascending: true, nullsLast: true })\n   117→        .order('created_at', { ascending: false })\n   118→      if (error) throw error\n   119→      setTasks(data || [])\n   120→    } finally {\n   121→      setLoading(false)\n   122→    }\n   123→  }\n   124→\n   125→  useEffect(() => {\n   126→    const hasSession = { current: false }\n   127→    const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {\n   128→      if (session) {\n   129→        hasSession.current = true\n   130→        setUser(session.user)\n   131→        if (event === 'INITIAL_SESSION' || event === 'SIGNED_IN') {\n   132→          fetchProfile(session.user.id)\n   133→          fetchTasks(session.user.id)\n   134→        }\n   135→      } else if (event === 'SIGNED_OUT' && hasSession.current) {\n   136→        router.push('/login')\n   137→      }\n   138→    })\n   139→    return () => subscription.unsubscribe()\n   140→  }, [])\n   141→\n   142→  // ── Voice FAB ────────────────────────────────────────────────────────────\n   143→  const startVoiceFab = () => {\n   144→    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition\n   145→    if (!SpeechRecognition) { libShowToast('Voice input not supported in this browser.', { type: 'error' }); return }\n   146→    const recognition = new SpeechRecognition()\n   147→    recognition.continuous = false\n   148→    recognition.interimResults = false\n   149→    recognition.lang = 'en-US'\n   150→    recognition.onstart = () => setVoiceFabState('recording')\n   151→    recognition.onresult = (event) => {\n   152→      const transcript = event.results[0][0].transcript\n   153→      setVoiceFabState('processing')\n   154→      handleVoiceInput(transcript)\n   155→    }\n   156→    recognition.onerror = () => { setVoiceFabState('idle'); libShowToast('Could not hear you. Try again.', { type: 'error' }) }\n   157→    recognition.onend = () => setVoiceFabState(prev => prev === 'recording' ? 'idle' : prev)\n   158→    voiceFabRecognitionRef.current = recognition\n   159→    recognition.start()"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"381406bb-a8b7-4cbc-900b-cf24d9686a30","timestamp":"2026-03-26T12:16:03.379Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/dashboard.js","content":"    try {\n      const savedColor = localStorage.getItem('fb_accent_color')\n      if (savedColor) {\n        const theme = THEMES.find(t => t.id === savedColor) || THEMES.find(t => t.accent === savedColor)\n        if (theme) applyTheme(theme)\n        else applyAccentColor(savedColor)\n      }\n    } catch {}\n  }, [])\n\n  useEffect(() => {\n    const hour = new Date().getHours()\n    if (hour < 12) setGreeting('Good morning')\n    else if (hour < 17) setGreeting('Good afternoon')\n    else setGreeting('Good evening')\n  }, [])\n\n  const fetchProfile = async (userId) => {\n    const { data } = await supabase.from('profiles').select('*').eq('id', userId).single()\n    if (data) {\n      setProfile(data)\n      if (data.accent_color) {\n        const savedTheme = THEMES.find(t => t.id === data.accent_color) || THEMES.find(t => t.accent === data.accent_color) || THEMES[0]\n        applyTheme(savedTheme)\n        setActiveTheme(savedTheme)\n        if (typeof localStorage !== 'undefined') localStorage.setItem('fb_accent_color', savedTheme.id)\n      }\n    } else {\n      router.push('/onboarding')\n    }\n  }\n\n  const fetchTasks = async (userId) => {\n    try {\n      const { data, error } = await supabase\n        .from('tasks').select('*').eq('user_id', userId).eq('archived', false)\n        .order('sort_order', { ascending: true, nullsLast: true })\n        .order('created_at', { ascending: false })\n      if (error) throw error\n      setTasks(data || [])\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    const hasSession = { current: false }\n    const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {\n      if (session) {\n        hasSession.current = true\n        setUser(session.user)\n        if (event === 'INITIAL_SESSION' || event === 'SIGNED_IN') {\n          fetchProfile(session.user.id)\n          fetchTasks(session.user.id)\n        }\n      } else if (event === 'SIGNED_OUT' && hasSession.current) {\n        router.push('/login')\n      }\n    })\n    return () => subscription.unsubscribe()\n  }, [])\n\n  // ── Voice FAB ────────────────────────────────────────────────────────────\n  const startVoiceFab = () => {\n    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition\n    if (!SpeechRecognition) { libShowToast('Voice input not supported in this browser.', { type: 'error' }); return }\n    const recognition = new SpeechRecognition()\n    recognition.continuous = false\n    recognition.interimResults = false\n    recognition.lang = 'en-US'\n    recognition.onstart = () => setVoiceFabState('recording')\n    recognition.onresult = (event) => {\n      const transcript = event.results[0][0].transcript\n      setVoiceFabState('processing')\n      handleVoiceInput(transcript)\n    }\n    recognition.onerror = () => { setVoiceFabState('idle'); libShowToast('Could not hear you. Try again.', { type: 'error' }) }\n    recognition.onend = () => setVoiceFabState(prev => prev === 'recording' ? 'idle' : prev)\n    voiceFabRecognitionRef.current = recognition\n    recognition.start()","numLines":80,"startLine":80,"totalLines":327}}}
