{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017CwGERdF5FZiySFfcNx1LF","type":"tool_result","content":"   160→  }\n   161→  const stopVoiceFab = () => voiceFabRecognitionRef.current?.stop()\n   162→  const handleVoiceFabClick = () => {\n   163→    if (voiceFabState === 'idle') startVoiceFab()\n   164→    else if (voiceFabState === 'recording') stopVoiceFab()\n   165→  }\n   166→  const handleVoiceInput = async (transcript) => {\n   167→    try {\n   168→      const res = await loggedFetch('/api/voice/parse', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ text: transcript }) })\n   169→      const data = await res.json()\n   170→      if (!res.ok || data.error) throw new Error(data.error || 'Failed')\n   171→      setVoiceFabState('idle')\n   172→      if (user) fetchTasks(user.id)\n   173→      libShowToast(`Created: ${data.message}`, { type: 'undo', duration: 5000, undoCallback: () => handleUndoVoiceTask(data.record.id, data.type) })\n   174→    } catch { setVoiceFabState('idle'); libShowToast('Could not create task. Try again.', { type: 'error' }) }\n   175→  }\n   176→  const handleUndoVoiceTask = async (id, type) => {\n   177→    try {\n   178→      if (type === 'bill') await loggedFetch(`/api/bills/${id}`, { method: 'DELETE' })\n   179→      else await loggedFetch(`/api/tasks/${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ archived: true }) })\n   180→      if (user) fetchTasks(user.id)\n   181→      libShowToast('Undone.', { type: 'success', duration: 2000 })\n   182→    } catch { libShowToast('Could not undo. Try again.', { type: 'error' }) }\n   183→  }\n   184→\n   185→  const handleSignOut = async () => { await supabase.auth.signOut(); router.push('/') }\n   186→  const handleRunRollover = async () => {\n   187→    try {\n   188→      const res = await loggedFetch('/api/rollover-tasks', { method: 'POST' })\n   189→      const data = await res.json()\n   190→      showToast(`Rolled ${data.rolled} task${data.rolled !== 1 ? 's' : ''}`)\n   191→      if (data.rolled > 0 && user) fetchTasks(user.id)\n   192→    } catch { showToast('Rollover failed') }\n   193→  }\n   194→\n   195→  // ── Render ───────────────────────────────────────────────────────────────\n   196→  if (loading) return (\n   197→    <div className={styles.loadingPage}>\n   198→      <span style={{ fontFamily: \"'Sora', sans-serif\", fontWeight: 600, fontSize: '1.3rem', letterSpacing: '0.16em', color: '#F5F0E3' }}>CINIS</span>\n   199→    </div>\n   200→  )\n   201→\n   202→  const tabProps = { user, profile, setProfile, tasks, setTasks, showToast, loggedFetch, switchTab }\n   203→\n   204→  return (\n   205→    <>\n   206→      <Head><title>Dashboard — Cinis</title></Head>\n   207→      <div className={styles.appShell}>\n   208→\n   209→        {/* SIDEBAR */}\n   210→        <aside className={styles.sidebar}>\n   211→          <div className={styles.sidebarLogo}>\n   212→            <svg width=\"24\" height=\"24\" viewBox=\"0 0 64 64\" fill=\"none\" aria-hidden=\"true\" style={{ flexShrink: 0 }}>\n   213→              <polygon points=\"32,2 56,15 56,43 32,56 8,43 8,15\" fill=\"none\" stroke=\"#FF6644\" strokeWidth=\"1.1\" opacity=\"0.45\"/>\n   214→              <path d=\"M 12.63,14.56 L 29.37,5.44 Q 32,4 34.63,5.44 L 51.37,14.56 Q 54,16 54,19 L 54,39 Q 54,42 51.37,43.44 L 34.63,52.56 Q 32,54 29.37,52.56 L 12.63,43.44 Q 10,42 10,39 L 10,19 Q 10,16 12.63,14.56 Z\" fill=\"#FF6644\"/>\n   215→              <path d=\"M 14.9,16.1 L 29.8,7.8 Q 32,6.6 34.2,7.8 L 49.1,16.1 Q 51.4,17.4 51.4,20 L 51.4,38 Q 51.4,40.6 49.1,41.9 L 34.2,50.2 Q 32,51.4 29.8,50.2 L 14.9,41.9 Q 12.6,40.6 12.6,38 L 12.6,20 Q 12.6,17.4 14.9,16.1 Z\" fill=\"#120704\"/>\n   216→              <polygon points=\"32,14 46,22 46,40 32,48 18,40 18,22\" fill=\"#5A1005\"/>\n   217→              <polygon points=\"32,20 42,26 42,40 32,45 22,40 22,26\" fill=\"#A82010\"/>\n   218→              <polygon points=\"32,26 38,29 38,40 32,43 26,40 26,29\" fill=\"#E8321A\"/>\n   219→              <polygon points=\"32,29 45,40 40,43 32,47 24,43 19,40\" fill=\"#FF6644\" opacity=\"0.92\"/>\n   220→              <polygon points=\"32,33 41,40 38,42 32,45 26,42 23,40\" fill=\"#FFD0C0\" opacity=\"0.76\"/>\n   221→              <polygon points=\"32,36 37,40 36,41 32,43 28,41 27,40\" fill=\"#FFF0EB\" opacity=\"0.60\"/>\n   222→            </svg>\n   223→            <div style={{ display: 'flex', flexDirection: 'column', gap: 2 }}>\n   224→              <span style={{ fontFamily: \"'Sora', sans-serif\", fontWeight: 600, fontSize: '0.85rem', letterSpacing: '0.16em', color: '#F5F0E3' }}>CINIS</span>\n   225→              <span style={{ fontFamily: \"'Figtree', sans-serif\", fontSize: '0.62rem', color: 'rgba(245,240,227,0.3)', letterSpacing: '0.01em', lineHeight: 1 }}>Where start meets finished.</span>\n   226→            </div>\n   227→          </div>\n   228→          <nav className={styles.sidebarNav}>\n   229→            {NAV_ITEMS.map(item => (\n   230→              <button key={item.id} onClick={() => switchTab(item.id)}\n   231→                className={`${styles.sidebarNavItem} ${activeTab === item.id ? styles.sidebarNavItemActive : ''}`}>\n   232→                <span className={styles.navIcon}>{item.icon}</span>\n   233→                <span className={styles.navLabel}>{item.label}</span>\n   234→              </button>\n   235→            ))}\n   236→          </nav>\n   237→          <div className={styles.sidebarFooter}>\n   238→            <span className={styles.sidebarEmail}>{user?.email}</span>\n   239→            <button onClick={handleSignOut} className={styles.signOutBtn}>Sign out</button>\n   240→            <button onClick={handleRunRollover} className={styles.rolloverDevBtn}>Run rollover</button>\n   241→          </div>\n   242→        </aside>\n   243→\n   244→        {/* MAIN */}\n   245→        <main className={styles.main}>\n   246→          {activeTab === 'tasks' && <TabErrorBoundary tabName=\"Tasks\"><TabTasks {...tabProps} /></TabErrorBoundary>}\n   247→          {activeTab === 'checkin' && <TabErrorBoundary tabName=\"Check-in\"><TabCheckin {...tabProps} /></TabErrorBoundary>}\n   248→          {activeTab === 'focus' && <TabErrorBoundary tabName=\"Focus\"><TabFocus {...tabProps} /></TabErrorBoundary>}\n   249→          {activeTab === 'calendar' && <TabErrorBoundary tabName=\"Calendar\"><TabCalendar {...tabProps} /></TabErrorBoundary>}\n   250→          {activeTab === 'habits' && <TabErrorBoundary tabName=\"Habits\"><TabHabits {...tabProps} /></TabErrorBoundary>}\n   251→          {activeTab === 'tagteam' && <TabErrorBoundary tabName=\"Tag Team\"><TabTagTeam {...tabProps} /></TabErrorBoundary>}\n   252→          {activeTab === 'finance' && <TabErrorBoundary tabName=\"Finance\"><TabFinance {...tabProps} /></TabErrorBoundary>}\n   253→          {activeTab === 'nutrition' && <TabErrorBoundary tabName=\"Nutrition\"><TabNutrition {...tabProps} /></TabErrorBoundary>}\n   254→          {activeTab === 'progress' && <TabErrorBoundary tabName=\"Progress\"><TabProgress {...tabProps} /></TabErrorBoundary>}\n   255→          {activeTab === 'guide' && <TabErrorBoundary tabName=\"Guide\"><TabGuide {...tabProps} /></TabErrorBoundary>}\n   256→          {activeTab === 'settings' && <TabErrorBoundary tabName=\"Settings\"><TabSettings {...tabProps} activeTheme={activeTheme} setActiveTheme={setActiveTheme} /></TabErrorBoundary>}\n   257→        </main>\n   258→\n   259→        {/* VOICE FAB */}\n   260→        <button\n   261→          className={`${styles.voiceFab} ${voiceFabState === 'recording' ? styles.voiceFabRecording : ''} ${voiceFabState === 'processing' ? styles.voiceFabProcessing : ''}`}\n   262→          onClick={handleVoiceFabClick}\n   263→          aria-label={voiceFabState === 'idle' ? 'Voice input' : voiceFabState === 'recording' ? 'Stop recording' : 'Processing'}\n   264→        >\n   265→          {voiceFabState === 'recording' ? (\n   266→            <div className={styles.voiceWaveBars}>\n   267→              <span className={styles.voiceWaveBar} />\n   268→              <span className={styles.voiceWaveBar} />\n   269→              <span className={styles.voiceWaveBar} />\n   270→            </div>\n   271→          ) : voiceFabState === 'processing' ? (\n   272→            <div className={styles.voiceFabSpinner} />\n   273→          ) : (\n   274→            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n   275→              <rect x=\"9\" y=\"2\" width=\"6\" height=\"12\" rx=\"3\" fill=\"white\"/>\n   276→              <path d=\"M5 11a7 7 0 0 0 14 0\" stroke=\"white\" strokeWidth=\"2\" strokeLinecap=\"round\"/>\n   277→              <line x1=\"12\" y1=\"18\" x2=\"12\" y2=\"22\" stroke=\"white\" strokeWidth=\"2\" strokeLinecap=\"round\"/>\n   278→              <line x1=\"9\" y1=\"22\" x2=\"15\" y2=\"22\" stroke=\"white\" strokeWidth=\"2\" strokeLinecap=\"round\"/>\n   279→            </svg>\n   280→          )}\n   281→        </button>\n   282→\n   283→        {/* TOAST */}\n   284→        <ToastContainer />\n   285→\n   286→        {/* BOTTOM NAV (mobile) */}\n   287→        <nav className={styles.bottomNav} aria-hidden=\"true\">\n   288→          {NAV_ITEMS.filter(i => NAV_PRIMARY_IDS.includes(i.id)).map(item => (\n   289→            <button key={item.id} onClick={() => switchTab(item.id)}\n   290→              className={`${styles.bottomNavItem} ${activeTab === item.id ? styles.bottomNavItemActive : ''}`}>\n   291→              <span className={styles.bottomNavIcon}>{item.icon}</span>\n   292→              <span className={styles.bottomNavLabel}>{item.label}</span>\n   293→            </button>\n   294→          ))}\n   295→          <button\n   296→            onClick={() => setShowMoreDrawer(true)}\n   297→            className={`${styles.bottomNavItem} ${NAV_MORE_IDS.includes(activeTab) ? styles.bottomNavItemActive : ''}`}>\n   298→            <span className={styles.bottomNavIcon}>\n   299→              <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n   300→                <circle cx=\"12\" cy=\"12\" r=\"1\"/><circle cx=\"19\" cy=\"12\" r=\"1\"/><circle cx=\"5\" cy=\"12\" r=\"1\"/>\n   301→              </svg>\n   302→            </span>\n   303→            <span className={styles.bottomNavLabel}>More</span>\n   304→          </button>\n   305→        </nav>\n   306→\n   307→        {/* MORE DRAWER (mobile) */}\n   308→        {showMoreDrawer && (\n   309→          <div className={styles.moreDrawerOverlay} onClick={() => setShowMoreDrawer(false)}>\n   310→            <div className={styles.moreDrawer} onClick={e => e.stopPropagation()}>\n   311→              <div className={styles.moreDrawerHandle} />\n   312→              {NAV_ITEMS.filter(i => NAV_MORE_IDS.includes(i.id)).map(item => (\n   313→                <button key={item.id} onClick={() => switchTab(item.id)}\n   314→                  className={`${styles.moreDrawerItem} ${activeTab === item.id ? styles.moreDrawerItemActive : ''}`}>\n   315→                  <span className={styles.navIcon}>{item.icon}</span>\n   316→                  <span>{item.label}</span>\n   317→                </button>\n   318→              ))}\n   319→            </div>\n   320→          </div>\n   321→        )}\n   322→\n   323→      </div>\n   324→    </>\n   325→  )\n   326→}\n   327→"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"ebc43df3-3b8c-497f-8432-b4677ecd9c23","timestamp":"2026-03-26T12:16:10.447Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/dashboard.js","content":"  }\n  const stopVoiceFab = () => voiceFabRecognitionRef.current?.stop()\n  const handleVoiceFabClick = () => {\n    if (voiceFabState === 'idle') startVoiceFab()\n    else if (voiceFabState === 'recording') stopVoiceFab()\n  }\n  const handleVoiceInput = async (transcript) => {\n    try {\n      const res = await loggedFetch('/api/voice/parse', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ text: transcript }) })\n      const data = await res.json()\n      if (!res.ok || data.error) throw new Error(data.error || 'Failed')\n      setVoiceFabState('idle')\n      if (user) fetchTasks(user.id)\n      libShowToast(`Created: ${data.message}`, { type: 'undo', duration: 5000, undoCallback: () => handleUndoVoiceTask(data.record.id, data.type) })\n    } catch { setVoiceFabState('idle'); libShowToast('Could not create task. Try again.', { type: 'error' }) }\n  }\n  const handleUndoVoiceTask = async (id, type) => {\n    try {\n      if (type === 'bill') await loggedFetch(`/api/bills/${id}`, { method: 'DELETE' })\n      else await loggedFetch(`/api/tasks/${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ archived: true }) })\n      if (user) fetchTasks(user.id)\n      libShowToast('Undone.', { type: 'success', duration: 2000 })\n    } catch { libShowToast('Could not undo. Try again.', { type: 'error' }) }\n  }\n\n  const handleSignOut = async () => { await supabase.auth.signOut(); router.push('/') }\n  const handleRunRollover = async () => {\n    try {\n      const res = await loggedFetch('/api/rollover-tasks', { method: 'POST' })\n      const data = await res.json()\n      showToast(`Rolled ${data.rolled} task${data.rolled !== 1 ? 's' : ''}`)\n      if (data.rolled > 0 && user) fetchTasks(user.id)\n    } catch { showToast('Rollover failed') }\n  }\n\n  // ── Render ───────────────────────────────────────────────────────────────\n  if (loading) return (\n    <div className={styles.loadingPage}>\n      <span style={{ fontFamily: \"'Sora', sans-serif\", fontWeight: 600, fontSize: '1.3rem', letterSpacing: '0.16em', color: '#F5F0E3' }}>CINIS</span>\n    </div>\n  )\n\n  const tabProps = { user, profile, setProfile, tasks, setTasks, showToast, loggedFetch, switchTab }\n\n  return (\n    <>\n      <Head><title>Dashboard — Cinis</title></Head>\n      <div className={styles.appShell}>\n\n        {/* SIDEBAR */}\n        <aside className={styles.sidebar}>\n          <div className={styles.sidebarLogo}>\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 64 64\" fill=\"none\" aria-hidden=\"true\" style={{ flexShrink: 0 }}>\n              <polygon points=\"32,2 56,15 56,43 32,56 8,43 8,15\" fill=\"none\" stroke=\"#FF6644\" strokeWidth=\"1.1\" opacity=\"0.45\"/>\n              <path d=\"M 12.63,14.56 L 29.37,5.44 Q 32,4 34.63,5.44 L 51.37,14.56 Q 54,16 54,19 L 54,39 Q 54,42 51.37,43.44 L 34.63,52.56 Q 32,54 29.37,52.56 L 12.63,43.44 Q 10,42 10,39 L 10,19 Q 10,16 12.63,14.56 Z\" fill=\"#FF6644\"/>\n              <path d=\"M 14.9,16.1 L 29.8,7.8 Q 32,6.6 34.2,7.8 L 49.1,16.1 Q 51.4,17.4 51.4,20 L 51.4,38 Q 51.4,40.6 49.1,41.9 L 34.2,50.2 Q 32,51.4 29.8,50.2 L 14.9,41.9 Q 12.6,40.6 12.6,38 L 12.6,20 Q 12.6,17.4 14.9,16.1 Z\" fill=\"#120704\"/>\n              <polygon points=\"32,14 46,22 46,40 32,48 18,40 18,22\" fill=\"#5A1005\"/>\n              <polygon points=\"32,20 42,26 42,40 32,45 22,40 22,26\" fill=\"#A82010\"/>\n              <polygon points=\"32,26 38,29 38,40 32,43 26,40 26,29\" fill=\"#E8321A\"/>\n              <polygon points=\"32,29 45,40 40,43 32,47 24,43 19,40\" fill=\"#FF6644\" opacity=\"0.92\"/>\n              <polygon points=\"32,33 41,40 38,42 32,45 26,42 23,40\" fill=\"#FFD0C0\" opacity=\"0.76\"/>\n              <polygon points=\"32,36 37,40 36,41 32,43 28,41 27,40\" fill=\"#FFF0EB\" opacity=\"0.60\"/>\n            </svg>\n            <div style={{ display: 'flex', flexDirection: 'column', gap: 2 }}>\n              <span style={{ fontFamily: \"'Sora', sans-serif\", fontWeight: 600, fontSize: '0.85rem', letterSpacing: '0.16em', color: '#F5F0E3' }}>CINIS</span>\n              <span style={{ fontFamily: \"'Figtree', sans-serif\", fontSize: '0.62rem', color: 'rgba(245,240,227,0.3)', letterSpacing: '0.01em', lineHeight: 1 }}>Where start meets finished.</span>\n            </div>\n          </div>\n          <nav className={styles.sidebarNav}>\n            {NAV_ITEMS.map(item => (\n              <button key={item.id} onClick={() => switchTab(item.id)}\n                className={`${styles.sidebarNavItem} ${activeTab === item.id ? styles.sidebarNavItemActive : ''}`}>\n                <span className={styles.navIcon}>{item.icon}</span>\n                <span className={styles.navLabel}>{item.label}</span>\n              </button>\n            ))}\n          </nav>\n          <div className={styles.sidebarFooter}>\n            <span className={styles.sidebarEmail}>{user?.email}</span>\n            <button onClick={handleSignOut} className={styles.signOutBtn}>Sign out</button>\n            <button onClick={handleRunRollover} className={styles.rolloverDevBtn}>Run rollover</button>\n          </div>\n        </aside>\n\n        {/* MAIN */}\n        <main className={styles.main}>\n          {activeTab === 'tasks' && <TabErrorBoundary tabName=\"Tasks\"><TabTasks {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'checkin' && <TabErrorBoundary tabName=\"Check-in\"><TabCheckin {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'focus' && <TabErrorBoundary tabName=\"Focus\"><TabFocus {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'calendar' && <TabErrorBoundary tabName=\"Calendar\"><TabCalendar {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'habits' && <TabErrorBoundary tabName=\"Habits\"><TabHabits {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'tagteam' && <TabErrorBoundary tabName=\"Tag Team\"><TabTagTeam {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'finance' && <TabErrorBoundary tabName=\"Finance\"><TabFinance {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'nutrition' && <TabErrorBoundary tabName=\"Nutrition\"><TabNutrition {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'progress' && <TabErrorBoundary tabName=\"Progress\"><TabProgress {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'guide' && <TabErrorBoundary tabName=\"Guide\"><TabGuide {...tabProps} /></TabErrorBoundary>}\n          {activeTab === 'settings' && <TabErrorBoundary tabName=\"Settings\"><TabSettings {...tabProps} activeTheme={activeTheme} setActiveTheme={setActiveTheme} /></TabErrorBoundary>}\n        </main>\n\n        {/* VOICE FAB */}\n        <button\n          className={`${styles.voiceFab} ${voiceFabState === 'recording' ? styles.voiceFabRecording : ''} ${voiceFabState === 'processing' ? styles.voiceFabProcessing : ''}`}\n          onClick={handleVoiceFabClick}\n          aria-label={voiceFabState === 'idle' ? 'Voice input' : voiceFabState === 'recording' ? 'Stop recording' : 'Processing'}\n        >\n          {voiceFabState === 'recording' ? (\n            <div className={styles.voiceWaveBars}>\n              <span className={styles.voiceWaveBar} />\n              <span className={styles.voiceWaveBar} />\n              <span className={styles.voiceWaveBar} />\n            </div>\n          ) : voiceFabState === 'processing' ? (\n            <div className={styles.voiceFabSpinner} />\n          ) : (\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <rect x=\"9\" y=\"2\" width=\"6\" height=\"12\" rx=\"3\" fill=\"white\"/>\n              <path d=\"M5 11a7 7 0 0 0 14 0\" stroke=\"white\" strokeWidth=\"2\" strokeLinecap=\"round\"/>\n              <line x1=\"12\" y1=\"18\" x2=\"12\" y2=\"22\" stroke=\"white\" strokeWidth=\"2\" strokeLinecap=\"round\"/>\n              <line x1=\"9\" y1=\"22\" x2=\"15\" y2=\"22\" stroke=\"white\" strokeWidth=\"2\" strokeLinecap=\"round\"/>\n            </svg>\n          )}\n        </button>\n\n        {/* TOAST */}\n        <ToastContainer />\n\n        {/* BOTTOM NAV (mobile) */}\n        <nav className={styles.bottomNav} aria-hidden=\"true\">\n          {NAV_ITEMS.filter(i => NAV_PRIMARY_IDS.includes(i.id)).map(item => (\n            <button key={item.id} onClick={() => switchTab(item.id)}\n              className={`${styles.bottomNavItem} ${activeTab === item.id ? styles.bottomNavItemActive : ''}`}>\n              <span className={styles.bottomNavIcon}>{item.icon}</span>\n              <span className={styles.bottomNavLabel}>{item.label}</span>\n            </button>\n          ))}\n          <button\n            onClick={() => setShowMoreDrawer(true)}\n            className={`${styles.bottomNavItem} ${NAV_MORE_IDS.includes(activeTab) ? styles.bottomNavItemActive : ''}`}>\n            <span className={styles.bottomNavIcon}>\n              <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <circle cx=\"12\" cy=\"12\" r=\"1\"/><circle cx=\"19\" cy=\"12\" r=\"1\"/><circle cx=\"5\" cy=\"12\" r=\"1\"/>\n              </svg>\n            </span>\n            <span className={styles.bottomNavLabel}>More</span>\n          </button>\n        </nav>\n\n        {/* MORE DRAWER (mobile) */}\n        {showMoreDrawer && (\n          <div className={styles.moreDrawerOverlay} onClick={() => setShowMoreDrawer(false)}>\n            <div className={styles.moreDrawer} onClick={e => e.stopPropagation()}>\n              <div className={styles.moreDrawerHandle} />\n              {NAV_ITEMS.filter(i => NAV_MORE_IDS.includes(i.id)).map(item => (\n                <button key={item.id} onClick={() => switchTab(item.id)}\n                  className={`${styles.moreDrawerItem} ${activeTab === item.id ? styles.moreDrawerItemActive : ''}`}>\n                  <span className={styles.navIcon}>{item.icon}</span>\n                  <span>{item.label}</span>\n                </button>\n              ))}\n            </div>\n          </div>\n        )}\n\n      </div>\n    </>\n  )\n}\n","numLines":168,"startLine":160,"totalLines":327}}}
