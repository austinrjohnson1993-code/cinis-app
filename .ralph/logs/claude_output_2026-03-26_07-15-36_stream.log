{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YQrSdVLSPVcq6fYSnidfL3","type":"tool_result","content":"   815→}\n   816→\n   817→// ── Handler ──────────────────────────────────────────────────────────────────\n   818→\n   819→export const config = { maxDuration: 30 }\n   820→\n   821→export default async function handler(req, res) {\n   822→  console.log('[checkin] API key prefix:', process.env.ANTHROPIC_API_KEY?.slice(0, 15))\n   823→  console.log('[checkin] API key length:', process.env.ANTHROPIC_API_KEY?.length)\n   824→\n   825→  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n   826→\n   827→  const { userId, checkInType, messages, timezone, tasks: clientTasks } = req.body\n   828→  if (!userId) return res.status(400).json({ error: 'userId required' })\n   829→\n   830→  // ── Next Move fast path ────────────────────────────────────────────────────\n   831→  if (checkInType === 'next_move') {\n   832→    try {\n   833→      const supabaseAdmin = getAdminClient()\n   834→      const { data: profile } = await supabaseAdmin.from('profiles').select('*').eq('id', userId).single()\n   835→      const baselineContext = profile?.baseline_profile ? `USER COACHING PROFILE:\\n${profile.baseline_profile}\\n\\n` : ''\n   836→      const personaBlend = profile?.persona_blend || ['coach']\n   837→      const personaBlendLabel = personaBlend\n   838→        .map(p => p.replace(/_/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase()))\n   839→        .join(', ')\n   840→      const nmStreak = profile?.current_streak || 0\n   841→      const nmLiveContext = `\\n\\nCurrent context:\\n- Streak: ${nmStreak} day${nmStreak !== 1 ? 's' : ''}\\n- Coaching persona: ${personaBlendLabel}`\n   842→      const isDrillSergeant = personaBlend[0] === 'drill_sergeant'\n   843→      const personaPriority = isDrillSergeant\n   844→        ? `PRIMARY PERSONA: DRILL SERGEANT. HARD RULES — NO EXCEPTIONS:\\n- NEVER open with praise, \"nice work\", \"good job\", or any positive affirmation\\n- NEVER end with a question — give a command instead\\n- Use SHORT sentences. Maximum 8 words per sentence.\\n- ALWAYS start with the task status or next action, not acknowledgment\\n- WRONG: \"Nice work on the dentist call. What's next?\"\\n- RIGHT: \"Dentist done. Insurance call is overdue. Make it now.\"\\n\\n`\n   845→        : `The user's PRIMARY persona is ${personaBlend[0]} — this voice must dominate. Secondary personas add subtle flavor only.\\n\\n`\n   846→      const systemPrompt = baselineContext + nmLiveContext + personaPriority + PERSONA_VOICE_INSTRUCTION + '\\n\\n' + buildPersonaPrompt(profile || {})\n   847→      console.log('[checkin:next_move:systemPrompt]', systemPrompt.slice(0, 1000))\n   848→      const pending = (clientTasks || []).filter(t => !t.completed && !t.archived)\n   849→      const taskLines = pending.length\n   850→        ? pending.slice(0, 10).map(t => {\n   851→            const due = t.due_time ? ` | due ${new Date(t.due_time).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}` : ''\n   852→            const rolled = t.rollover_count > 0 ? ` | rolled ${t.rollover_count}x` : ''\n   853→            const ext = t.consequence_level === 'external' ? ' | external' : ''\n   854→            return `- \"${t.title}\"${due}${rolled}${ext}`\n   855→          }).join('\\n')\n   856→        : '- no pending tasks'\n   857→      const prompt = `The user has tapped \"What's my next move?\" on their task list. Here are their pending tasks:\\n${taskLines}\\n\\nRespond with exactly ONE directive. Name the single best task to start right now in **bold**. Add one sentence explaining why (due time, external commitment, or momentum). Total response: under 30 words. No greeting, no filler.`\n   858→      const { text } = await callClaude(\n   859→        [{ role: 'user', content: prompt }],\n   860→        systemPrompt,\n   861→        false\n   862→      )\n   863→      return res.status(200).json({ message: text })\n   864→    } catch (err) {"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"4a86bcd2-324d-4910-b919-26e4878ee305","timestamp":"2026-03-26T12:16:22.673Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/api/checkin.js","content":"}\n\n// ── Handler ──────────────────────────────────────────────────────────────────\n\nexport const config = { maxDuration: 30 }\n\nexport default async function handler(req, res) {\n  console.log('[checkin] API key prefix:', process.env.ANTHROPIC_API_KEY?.slice(0, 15))\n  console.log('[checkin] API key length:', process.env.ANTHROPIC_API_KEY?.length)\n\n  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n\n  const { userId, checkInType, messages, timezone, tasks: clientTasks } = req.body\n  if (!userId) return res.status(400).json({ error: 'userId required' })\n\n  // ── Next Move fast path ────────────────────────────────────────────────────\n  if (checkInType === 'next_move') {\n    try {\n      const supabaseAdmin = getAdminClient()\n      const { data: profile } = await supabaseAdmin.from('profiles').select('*').eq('id', userId).single()\n      const baselineContext = profile?.baseline_profile ? `USER COACHING PROFILE:\\n${profile.baseline_profile}\\n\\n` : ''\n      const personaBlend = profile?.persona_blend || ['coach']\n      const personaBlendLabel = personaBlend\n        .map(p => p.replace(/_/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase()))\n        .join(', ')\n      const nmStreak = profile?.current_streak || 0\n      const nmLiveContext = `\\n\\nCurrent context:\\n- Streak: ${nmStreak} day${nmStreak !== 1 ? 's' : ''}\\n- Coaching persona: ${personaBlendLabel}`\n      const isDrillSergeant = personaBlend[0] === 'drill_sergeant'\n      const personaPriority = isDrillSergeant\n        ? `PRIMARY PERSONA: DRILL SERGEANT. HARD RULES — NO EXCEPTIONS:\\n- NEVER open with praise, \"nice work\", \"good job\", or any positive affirmation\\n- NEVER end with a question — give a command instead\\n- Use SHORT sentences. Maximum 8 words per sentence.\\n- ALWAYS start with the task status or next action, not acknowledgment\\n- WRONG: \"Nice work on the dentist call. What's next?\"\\n- RIGHT: \"Dentist done. Insurance call is overdue. Make it now.\"\\n\\n`\n        : `The user's PRIMARY persona is ${personaBlend[0]} — this voice must dominate. Secondary personas add subtle flavor only.\\n\\n`\n      const systemPrompt = baselineContext + nmLiveContext + personaPriority + PERSONA_VOICE_INSTRUCTION + '\\n\\n' + buildPersonaPrompt(profile || {})\n      console.log('[checkin:next_move:systemPrompt]', systemPrompt.slice(0, 1000))\n      const pending = (clientTasks || []).filter(t => !t.completed && !t.archived)\n      const taskLines = pending.length\n        ? pending.slice(0, 10).map(t => {\n            const due = t.due_time ? ` | due ${new Date(t.due_time).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}` : ''\n            const rolled = t.rollover_count > 0 ? ` | rolled ${t.rollover_count}x` : ''\n            const ext = t.consequence_level === 'external' ? ' | external' : ''\n            return `- \"${t.title}\"${due}${rolled}${ext}`\n          }).join('\\n')\n        : '- no pending tasks'\n      const prompt = `The user has tapped \"What's my next move?\" on their task list. Here are their pending tasks:\\n${taskLines}\\n\\nRespond with exactly ONE directive. Name the single best task to start right now in **bold**. Add one sentence explaining why (due time, external commitment, or momentum). Total response: under 30 words. No greeting, no filler.`\n      const { text } = await callClaude(\n        [{ role: 'user', content: prompt }],\n        systemPrompt,\n        false\n      )\n      return res.status(200).json({ message: text })\n    } catch (err) {","numLines":50,"startLine":815,"totalLines":1180}}}
