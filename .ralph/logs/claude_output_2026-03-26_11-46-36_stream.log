{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015wkAYQbc4XmJ4A8ZSfnJLc","type":"tool_result","content":"     1→import React, { useState, useEffect, useRef, useCallback } from 'react'\n     2→import { supabase } from '../lib/supabase'\n     3→import { useRouter } from 'next/router'\n     4→import Head from 'next/head'\n     5→import styles from '../styles/Dashboard.module.css'\n     6→import { CheckSquare, ChatCircle, Target, CalendarBlank, Wallet, ChartLineUp, Gear, ArrowCounterClockwise, UsersThree, BowlFood, Books } from '@phosphor-icons/react'\n     7→import { showToast as libShowToast, ToastContainer } from '../lib/toast.js'\n     8→import { applyAccentColor } from '../lib/accentColor'\n     9→import { THEMES, applyTheme, TabErrorBoundary } from '../components/tabs/shared'\n    10→\n    11→// Tab components\n    12→import TabTasks from '../components/tabs/TabTasks'\n    13→import TabCheckin from '../components/tabs/TabCheckin'\n    14→import TabFocus from '../components/tabs/TabFocus'\n    15→import TabCalendar from '../components/tabs/TabCalendar'\n    16→import TabHabits from '../components/tabs/TabHabits'\n    17→import TabTagTeam from '../components/tabs/TabTagTeam'\n    18→import TabFinance from '../components/tabs/TabFinance'\n    19→import TabNutrition from '../components/tabs/TabNutrition'\n    20→import TabProgress from '../components/tabs/TabProgress'\n    21→import TabGuide from '../components/tabs/TabGuide'\n    22→import TabSettings from '../components/tabs/TabSettings'\n    23→\n    24→// ── Nav config ──────────────────────────────────────────────────────────────\n    25→const NAV_ITEMS = [\n    26→  { id: 'tasks', label: 'Tasks', icon: <CheckSquare size={22} /> },\n    27→  { id: 'checkin', label: 'Check-in', icon: <ChatCircle size={22} /> },\n    28→  { id: 'focus', label: 'Focus', icon: <Target size={22} /> },\n    29→  { id: 'calendar', label: 'Calendar', icon: <CalendarBlank size={22} /> },\n    30→  { id: 'habits', label: 'Habits', icon: <ArrowCounterClockwise size={22} /> },\n    31→  { id: 'tagteam', label: 'Tag Team', icon: <UsersThree size={22} /> },\n    32→  { id: 'finance', label: 'Finance', icon: <Wallet size={22} /> },\n    33→  { id: 'nutrition', label: 'Nutrition', icon: <BowlFood size={22} /> },\n    34→  { id: 'progress', label: 'Progress', icon: <ChartLineUp size={22} /> },\n    35→  { id: 'guide', label: 'Guide', icon: <Books size={22} /> },\n    36→  { id: 'settings', label: 'Settings', icon: <Gear size={22} /> },\n    37→]\n    38→const NAV_PRIMARY_IDS = ['tasks', 'checkin', 'focus', 'calendar']\n    39→const NAV_MORE_IDS = ['habits', 'tagteam', 'finance', 'nutrition', 'progress', 'guide', 'settings']\n    40→\n    41→export default function Dashboard() {\n    42→  const router = useRouter()\n    43→  const [user, setUser] = useState(null)\n    44→  const [profile, setProfile] = useState(null)\n    45→  const [tasks, setTasks] = useState([])\n    46→  const [loading, setLoading] = useState(true)\n    47→  const [activeTab, setActiveTab] = useState('tasks')\n    48→  const [greeting, setGreeting] = useState('')\n    49→  const [activeTheme, setActiveTheme] = useState(THEMES[0])\n    50→  const [showMoreDrawer, setShowMoreDrawer] = useState(false)\n    51→\n    52→  // Voice FAB\n    53→  const [voiceFabState, setVoiceFabState] = useState('idle')\n    54→  const voiceFabRecognitionRef = useRef(null)\n    55→\n    56→  // Debug\n    57→  const debugRef = useRef({ lastCall: null, lastError: null })\n    58→  const isDebug = typeof window !== 'undefined' && window.location.search.includes('debug=true')\n    59→\n    60→  const loggedFetch = useCallback(async (url, opts = {}) => {\n    61→    const t0 = Date.now()\n    62→    try {\n    63→      const res = await fetch(url, opts)\n    64→      const clone = res.clone()\n    65→      const text = await clone.text().catch(() => '')\n    66→      debugRef.current.lastCall = { endpoint: url, method: opts.method || 'GET