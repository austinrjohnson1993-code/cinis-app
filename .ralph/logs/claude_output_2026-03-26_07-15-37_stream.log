{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TfgMDZyWy1MS1mJRJXngMV","type":"tool_result","content":"   821→export default async function handler(req, res) {\n   822→  console.log('[checkin] API key prefix:', process.env.ANTHROPIC_API_KEY?.slice(0, 15))\n   823→  console.log('[checkin] API key length:', process.env.ANTHROPIC_API_KEY?.length)\n   824→\n   825→  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n   826→\n   827→  const { userId, checkInType, messages, timezone, tasks: clientTasks } = req.body\n   828→  if (!userId) return res.status(400).json({ error: 'userId required' })\n   829→\n   830→  // ── Next Move fast path ────────────────────────────────────────────────────\n   831→  if (checkInType === 'next_move') {\n   832→    try {\n   833→      const supabaseAdmin = getAdminClient()\n   834→      const { data: profile } = await supabaseAdmin.from('profiles').select('*').eq('id', userId).single()\n   835→      const baselineContext = profile?.baseline_profile ? `USER COACHING PROFILE:\\n${profile.baseline_profile}\\n\\n` : ''\n   836→      const personaBlend = profile?.persona_blend || ['coach']\n   837→      const personaBlendLabel = personaBlend\n   838→        .map(p => p.replace(/_/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase()))\n   839→        .join(', ')\n   840→      const nmStreak = profile?.current_streak || 0\n   841→      const nmLiveContext = `\\n\\nCurrent context:\\n- Streak: ${nmStreak} day${nmStreak !== 1 ? 's' : ''}\\n- Coaching persona: ${personaBlendLabel}`\n   842→      const isDrillSergeant = personaBlend[0] === 'drill_sergeant'\n   843→      const personaPriority = isDrillSergeant\n   844→        ? `PRIMARY PERSONA: DRILL SERGEANT. HARD RULES — NO EXCEPTIONS:\\n- NEVER open with praise, \"nice work\", \"good job\", or any positive affirmation\\n- NEVER end with a question — give a command instead\\n- Use SHORT sentences. Maximum 8 words per sentence.\\n- ALWAYS start with the task status or next action, not acknowledgment\\n- WRONG: \"Nice work on the dentist call. What's next?\"\\n- RIGHT: \"Dentist done. Insurance call is overdue. Make it now.\"\\n\\n`\n   845→        : `The user's PRIMARY persona is ${personaBlend[0]} — this voice must dominate. Secondary personas add subtle flavor only.\\n\\n`\n   846→      const systemPrompt = baselineContext + nmLiveContext + personaPriority + PERSONA_VOICE_INSTRUCTION + '\\n\\n' + buildPersonaPrompt(profile || {})\n   847→      console.log('[checkin:next_move:systemPrompt]', systemPrompt.slice(0, 1000))\n   848→      const pending = (clientTasks || []).filter(t => !t.completed && !t.archived)\n   849→      const taskLines = pending.length\n   850→        ? pending.slice(0, 10).map(t => {\n   851→            const due = t.due_time ? ` | due ${new Date(t.due_time).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}` : ''\n   852→            const rolled = t.rollover_count > 0 ? ` | rolled ${t.rollover_count}x` : ''\n   853→            const ext = t.consequence_level === 'external' ? ' | external' : ''\n   854→            return `- \"${t.title}\"${due}${rolled}${ext}`\n   855→          }).join('\\n')\n   856→        : '- no pending tasks'\n   857→      const prompt = `The user has tapped \"What's my next move?\" on their task list. Here are their pending tasks:\\n${taskLines}\\n\\nRespond with exactly ONE directive. Name the single best task to start right now in **bold**. Add one sentence explaining why (due time, external commitment, or momentum). Total response: under 30 words. No greeting, no filler.`\n   858→      const { text } = await callClaude(\n   859→        [{ role: 'user', content: prompt }],\n   860→        systemPrompt,\n   861→        false\n   862→      )\n   863→      return res.status(200).json({ message: text })\n   864→    } catch (err) {\n   865→      console.error('[checkin] next_move error:', err.message)\n   866→      return res.status(500).json({ error: 'Failed to get next move' })\n   867→    }\n   868→  }\n   869→\n   870→  const userMessage = req.body.content || req.body.message || ''\n   871→  if (userMessage.length > 2000) {\n   872→    return res.status(400).json({ error: 'Message too long. Please keep messages under 2000 characters.' })\n   873→  }\n   874→\n   875→  const rateCheck = await checkDailyRateLimit(userId)\n   876→  if (!rateCheck.allowed) {\n   877→    return res.status(429).json(rateLimitErrorResponse(rateCheck))\n   878→  }\n   879→\n   880→  const todayStr = new Date().toLocaleDateString('en-CA', { timeZone: timezone || 'America/Chicago' })\n   881→  const tomorrowStr = new Date(Date.now() + 86400000).toLocaleDateString('en-CA', { timeZone: timezone || 'America/Chicago' })\n   882→\n   883→  try {\n   884→  const supabaseAdmin = getAdminClient()\n   885→\n   886→  // One-time cleanup: remove any stale \"Morning check-in\" tasks created by old tool code\n   887→  supabaseAdmin.from('tasks')\n   888→    .delete()\n   889→    .eq('user_id', userId)\n   890→    .eq('title', 'Morning check-in with Cinis')\n   891→\n   892→  const { data: profile, error: profileErr } = await supabaseAdmin\n   893→    .from('profiles').select('*').eq('id', userId).single()\n   894→  if (profileErr || !profile) {\n   895→    console.error('[checkin] profile fetch error:', JSON.stringify(profileErr))\n   896→    return res.status(404).json({ error: 'Profile not found' })\n   897→  }\n   898→\n   899→  // ── Fetch tasks and crews early so live context can be injected into system prompt ────\n   900→  const { data: allTasks = [] } = await supabaseAdmin\n   901→    .from('tasks').select('*').eq('user_id', userId).eq('archived', false)\n   902→\n   903→  // Fetch bills for injection with IDs so AI can call update_bill\n   904→  const { data: allBills = [] } = await supabaseAdmin\n   905→    .from('bills').select('*').eq('user_id', userId)\n   906→\n   907→  // Fetch user's crews (where they're owner or member)\n   908→  const { data: userCrews = [] } = await supabaseAdmin\n   909→    .from('crews')\n   910→    .select('id, name, type, owner_id')\n   911→    .or(`owner_id.eq.${userId},crew_members(crew_id,user_id).eq.user_id,${userId}`)\n   912→\n   913→  // Fetch crew members for each crew\n   914→  let crewContextStr = ''\n   915→  if (userCrews && userCrews.length > 0) {\n   916→    const crewsList = []\n   917→    for (const crew of userCrews) {\n   918→      const { data: members = [] } = await supabaseAdmin\n   919→        .from('crew_members')\n   920→        .select('user_id, profiles(id, full_name)')\n   921→        .eq('crew_id', crew.id)\n   922→\n   923→      crewsList.push({\n   924→        id: crew.id,\n   925→        name: crew.name,\n   926→        type: crew.type,\n   927→        members: members.map(m => ({ id: m.user_id, name: m.profiles?.full_name || 'Unknown' }))\n   928→      })\n   929→    }\n   930→    if (crewsList.length > 0) {\n   931→      crewContextStr = `\\n- Your crews: ${JSON.stringify(crewsList)}`\n   932→    }\n   933→  }\n   934→\n   935→  const allPending = (allTasks || []).filter(t => !t.completed)\n   936→  const allCompleted = (allTasks || []).filter(t => t.completed)\n   937→  const overdueCount = allPending.filter(t => t.scheduled_for && t.scheduled_for.slice(0, 10) < todayStr).length\n   938→  const currentStreak = profile.current_streak || 0\n   939→  const taskLines = allPending.slice(0, 12).map(t => {\n   940→    let label = `- \"${t.title}\" | id:${t.id} | sched:${(t.scheduled_for || '').slice(0, 10)}`\n   941→    if ((t.rollover_count || 0) > 0) label += ` | rolled:${t.rollover_count}×`\n   942→    return label\n   943→  })\n   944→  const taskSummary = taskLines.length > 0 ? '\\n' + taskLines.join('\\n') : 'none'\n   945→\n   946→  // Format bills with IDs for AI tool calls\n   947→  const billLines = allBills.slice(0, 8).map(b => {\n   948→    return `- \"${b.name}\" | id:${b.id} | amount:$${(b.amount || 0).toFixed(2)} | due_day:${b.due_day} | frequency:${b.frequency || 'monthly'} | autopay:${b.autopay ? 'yes' : 'no'}`\n   949→  })\n   950→  const billSummary = billLines.length > 0 ? '\\n' + billLines.join('\\n') : 'none'\n   951→\n   952→  // Calculate full finance context\n   953→  const monthlyTotal = (allBills || []).reduce((sum, b) => sum + (b.amount || 0), 0)\n   954→  const monthlyIncome = profile?.monthly_income || null\n   955→  const dailyNumber = monthlyIncome ? ((monthlyIncome - monthlyTotal) / 30).toFixed(2) : null\n   956→\n   957→  // Fetch today's spending\n   958→  const todayLocalStr = new Date().toLocaleDateString('en-CA', { timeZone: timezone || 'America/Chicago' })\n   959→  const { data: todaySpends = [] } = await supabaseAdmin\n   960→    .from('spend_log')\n   961→    .select('*')\n   962→    .eq('user_id', userId)\n   963→    .gte('created_at', `${todayLocalStr}T00:00:00`)\n   964→    .lt('created_at', `${todayLocalStr}T23:59:59`)\n   965→\n   966→  const totalTodaySpent = (todaySpends || []).reduce((sum, s) => sum + (s.amount || 0), 0)\n   967→  const remainingToday = dailyNumber ? (dailyNumber - totalTodaySpent).toFixed(2) : null\n   968→\n   969→  // Format today's spending\n   970→  let todaySpendStr = ''"}]},"parent_tool_use_id":"toolu_016AACCY39huMRvxZN2Eihwg","session_id":"c92e3624-e3e3-45f1-ae19-e176495ae8ad","uuid":"def68427-4cef-4302-92f0-f8ec72e7d7b7","timestamp":"2026-03-26T12:16:02.200Z"}
