{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M7kzHsBqw5pdkPe5Y5XYYh","type":"tool_result","content":"     1→import { createClient } from '@supabase/supabase-js'\n     2→import withAuth from '../../../lib/authGuard'\n     3→\n     4→function getAdminClient() {\n     5→  return createClient(\n     6→    process.env.NEXT_PUBLIC_SUPABASE_URL,\n     7→    process.env.SUPABASE_SERVICE_ROLE_KEY\n     8→  )\n     9→}\n    10→\n    11→async function handler(req, res, userId) {\n    12→  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n    13→\n    14→  const { subscription, enabled } = req.body\n    15→\n    16→  const supabase = getAdminClient()\n    17→\n    18→  // Unsubscribe path\n    19→  if (enabled === false) {\n    20→    await supabase\n    21→      .from('profiles')\n    22→      .update({ push_notifications_enabled: false, push_subscription: null })\n    23→      .eq('id', userId)\n    24→    return res.status(200).json({ success: true, enabled: false })\n    25→  }\n    26→\n    27→  // Subscribe path\n    28→  if (!subscription || !subscription.endpoint) {\n    29→    return res.status(400).json({ error: 'Invalid subscription object' })\n    30→  }\n    31→\n    32→  const { error } = await supabase\n    33→    .from('profiles')\n    34→    .update({\n    35→      push_subscription: subscription,\n    36→      push_notifications_enabled: true\n    37→    })\n    38→    .eq('id', userId)\n    39→\n    40→  if (error) return res.status(500).json({ error: error.message })\n    41→  return res.status(200).json({ success: true, enabled: true })\n    42→}\n    43→\n    44→export default withAuth(handler)\n    45→"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"004f58f2-f908-4c6b-bc16-ccd64507ae29","timestamp":"2026-03-26T12:03:39.179Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/api/notifications/subscribe.js","content":"import { createClient } from '@supabase/supabase-js'\nimport withAuth from '../../../lib/authGuard'\n\nfunction getAdminClient() {\n  return createClient(\n    process.env.NEXT_PUBLIC_SUPABASE_URL,\n    process.env.SUPABASE_SERVICE_ROLE_KEY\n  )\n}\n\nasync function handler(req, res, userId) {\n  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n\n  const { subscription, enabled } = req.body\n\n  const supabase = getAdminClient()\n\n  // Unsubscribe path\n  if (enabled === false) {\n    await supabase\n      .from('profiles')\n      .update({ push_notifications_enabled: false, push_subscription: null })\n      .eq('id', userId)\n    return res.status(200).json({ success: true, enabled: false })\n  }\n\n  // Subscribe path\n  if (!subscription || !subscription.endpoint) {\n    return res.status(400).json({ error: 'Invalid subscription object' })\n  }\n\n  const { error } = await supabase\n    .from('profiles')\n    .update({\n      push_subscription: subscription,\n      push_notifications_enabled: true\n    })\n    .eq('id', userId)\n\n  if (error) return res.status(500).json({ error: error.message })\n  return res.status(200).json({ success: true, enabled: true })\n}\n\nexport default withAuth(handler)\n","numLines":45,"startLine":1,"totalLines":45}}}
