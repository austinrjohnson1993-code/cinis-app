{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H6kLYrwY5kR1EW4CGuVjzd","type":"tool_result","content":"     1→import { createClient } from '@supabase/supabase-js'\n     2→import { buildPersonaPrompt } from '../../../lib/persona'\n     3→import { coachingMessage } from '../../../lib/anthropic'\n     4→const { sendPushToUsers } = require('../../../lib/push')\n     5→\n     6→function getAdminClient() {\n     7→  return createClient(\n     8→    process.env.NEXT_PUBLIC_SUPABASE_URL,\n     9→    process.env.SUPABASE_SERVICE_ROLE_KEY\n    10→  )\n    11→}\n    12→\n    13→function fmtTask(t) {\n    14→  let s = `\"${t.title}\"`\n    15→  if ((t.rollover_count || 0) > 0) s += ` [rolled ${t.rollover_count}×]`\n    16→  if (t.due_time) s += ` [due ${new Date(t.due_time).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })}]`\n    17→  if (t.consequence_level === 'external') s += ' [external]'\n    18→  return s\n    19→}\n    20→\n    21→function topTask(pending) {\n    22→  return pending.find(t => t.consequence_level === 'external' || t.due_time)\n    23→    || pending.find(t => (t.rollover_count || 0) > 0)\n    24→    || pending[0]\n    25→    || null\n    26→}\n    27→\n    28→// Called daily at 8AM by Vercel cron (see vercel.json)\n    29→export default async function handler(req, res) {\n    30→  const authHeader = req.headers.authorization\n    31→  if (!process.env.CRON_SECRET || authHeader !== `Bearer ${process.env.CRON_SECRET}`) {\n    32→    return res.status(401).json({ error: 'Unauthorized' })\n    33→  }\n    34→\n    35→  const supabaseAdmin = getAdminClient()\n    36→\n    37→  const { data: profiles } = await supabaseAdmin\n    38→    .from('profiles')\n    39→    .select('*')\n    40→    .contains('checkin_times', ['morning'])\n    41→\n    42→  if (!profiles || profiles.length === 0) {\n    43→    return res.status(200).json({ success: true, pregenerated: 0 })\n    44→  }\n    45→\n    46→  let pregenerated = 0\n    47→\n    48→  await Promise.allSettled(profiles.map(async (profile) => {\n    49→    try {\n    50→      const { data: tasks = [] } = await supabaseAdmin\n    51→        .from('tasks').select('*').eq('user_id', profile.id).eq('archived', false)\n    52→\n    53→      const pending = (tasks || []).filter(t => !t.completed)\n    54→      const name = profile.full_name?.split(' ')[0] || 'there'\n    55→      const top = topTask(pending)\n    56→\n    57→      const topLine = top\n    58→        ? `Top priority: ${fmtTask(top)}.`\n    59→        : 'No pending tasks today.'\n    60→\n    61→      const allPendingLine = pending.length > 1\n    62→        ? `Also pending: ${pending.filter(t => t !== top).map(fmtTask).join(', ')}.`\n    63→        : ''\n    64→\n    65→      const contextPrompt = `It's morning. ${name} is starting their day. ${topLine} ${allPendingLine} Write the morning check-in. 2-3 sentences max. Name the top task specifically. Be direct and energizing.`\n    66→\n    67→      const systemPrompt = buildPersonaPrompt(profile)\n    68→      const message = await coachingMessage(\n    69→        [{ role: 'user', content: contextPrompt }],\n    70→        systemPrompt\n    71→      )\n    72→\n    73→      await supabaseAdmin.from('profiles').update({\n    74→        last_checkin_message: message,\n    75→        last_checkin_at: new Date().toISOString()\n    76→      }).eq('id', profile.id)\n    77→\n    78→      pregenerated++\n    79→      console.log(`[morning-checkin] Pre-generated for ${name}`)\n    80→    } catch (err) {\n    81→      console.error(`[morning-checkin] Pre-gen failed for ${profile.id}:`, err.message)\n    82→    }\n    83→  }))\n    84→\n    85→  // Send push notifications to all eligible morning users\n    86→  const userIds = profiles.map(p => p.id)\n    87→  try {\n    88→    await sendPushToUsers(supabaseAdmin, userIds, {\n    89→      title: 'Good morning, Cinis.',\n    90→      body: \"Your day is ready. What's the move?\",\n    91→      tag: 'cinis-morning',\n    92→      url: '/dashboard'\n    93→    })\n    94→    console.log(`[morning-checkin] Push sent to ${userIds.length} users`)\n    95→  } catch (pushErr) {\n    96→    console.error('[morning-checkin] Batch push error:', pushErr.message)\n    97→  }\n    98→\n    99→  return res.status(200).json({ success: true, pregenerated })\n   100→}\n   101→"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"147dfdc7-c378-459c-9bcd-5481f2d34af2","timestamp":"2026-03-26T12:03:31.413Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/api/cron/morning-checkin.js","content":"import { createClient } from '@supabase/supabase-js'\nimport { buildPersonaPrompt } from '../../../lib/persona'\nimport { coachingMessage } from '../../../lib/anthropic'\nconst { sendPushToUsers } = require('../../../lib/push')\n\nfunction getAdminClient() {\n  return createClient(\n    process.env.NEXT_PUBLIC_SUPABASE_URL,\n    process.env.SUPABASE_SERVICE_ROLE_KEY\n  )\n}\n\nfunction fmtTask(t) {\n  let s = `\"${t.title}\"`\n  if ((t.rollover_count || 0) > 0) s += ` [rolled ${t.rollover_count}×]`\n  if (t.due_time) s += ` [due ${new Date(t.due_time).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })}]`\n  if (t.consequence_level === 'external') s += ' [external]'\n  return s\n}\n\nfunction topTask(pending) {\n  return pending.find(t => t.consequence_level === 'external' || t.due_time)\n    || pending.find(t => (t.rollover_count || 0) > 0)\n    || pending[0]\n    || null\n}\n\n// Called daily at 8AM by Vercel cron (see vercel.json)\nexport default async function handler(req, res) {\n  const authHeader = req.headers.authorization\n  if (!process.env.CRON_SECRET || authHeader !== `Bearer ${process.env.CRON_SECRET}`) {\n    return res.status(401).json({ error: 'Unauthorized' })\n  }\n\n  const supabaseAdmin = getAdminClient()\n\n  const { data: profiles } = await supabaseAdmin\n    .from('profiles')\n    .select('*')\n    .contains('checkin_times', ['morning'])\n\n  if (!profiles || profiles.length === 0) {\n    return res.status(200).json({ success: true, pregenerated: 0 })\n  }\n\n  let pregenerated = 0\n\n  await Promise.allSettled(profiles.map(async (profile) => {\n    try {\n      const { data: tasks = [] } = await supabaseAdmin\n        .from('tasks').select('*').eq('user_id', profile.id).eq('archived', false)\n\n      const pending = (tasks || []).filter(t => !t.completed)\n      const name = profile.full_name?.split(' ')[0] || 'there'\n      const top = topTask(pending)\n\n      const topLine = top\n        ? `Top priority: ${fmtTask(top)}.`\n        : 'No pending tasks today.'\n\n      const allPendingLine = pending.length > 1\n        ? `Also pending: ${pending.filter(t => t !== top).map(fmtTask).join(', ')}.`\n        : ''\n\n      const contextPrompt = `It's morning. ${name} is starting their day. ${topLine} ${allPendingLine} Write the morning check-in. 2-3 sentences max. Name the top task specifically. Be direct and energizing.`\n\n      const systemPrompt = buildPersonaPrompt(profile)\n      const message = await coachingMessage(\n        [{ role: 'user', content: contextPrompt }],\n        systemPrompt\n      )\n\n      await supabaseAdmin.from('profiles').update({\n        last_checkin_message: message,\n        last_checkin_at: new Date().toISOString()\n      }).eq('id', profile.id)\n\n      pregenerated++\n      console.log(`[morning-checkin] Pre-generated for ${name}`)\n    } catch (err) {\n      console.error(`[morning-checkin] Pre-gen failed for ${profile.id}:`, err.message)\n    }\n  }))\n\n  // Send push notifications to all eligible morning users\n  const userIds = profiles.map(p => p.id)\n  try {\n    await sendPushToUsers(supabaseAdmin, userIds, {\n      title: 'Good morning, Cinis.',\n      body: \"Your day is ready. What's the move?\",\n      tag: 'cinis-morning',\n      url: '/dashboard'\n    })\n    console.log(`[morning-checkin] Push sent to ${userIds.length} users`)\n  } catch (pushErr) {\n    console.error('[morning-checkin] Batch push error:', pushErr.message)\n  }\n\n  return res.status(200).json({ success: true, pregenerated })\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
