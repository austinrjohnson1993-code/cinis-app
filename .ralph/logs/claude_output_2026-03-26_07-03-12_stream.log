{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019wAS1Y8mt24e6uuQL1fnmy","type":"tool_result","content":"     1→import { createClient } from '@supabase/supabase-js'\n     2→import { runRollover } from '../rollover-tasks'\n     3→import { runBillsToTasks } from '../bills-to-tasks'\n     4→import { runProgressSnapshot } from '../progress-snapshot'\n     5→import { buildPersonaPrompt } from '../../../lib/persona'\n     6→import { coachingMessage } from '../../../lib/anthropic'\n     7→const { sendPushToUsers } = require('../../../lib/push')\n     8→\n     9→function getAdminClient() {\n    10→  return createClient(\n    11→    process.env.NEXT_PUBLIC_SUPABASE_URL,\n    12→    process.env.SUPABASE_SERVICE_ROLE_KEY\n    13→  )\n    14→}\n    15→\n    16→function fmtTask(t) {\n    17→  let s = `\"${t.title}\"`\n    18→  if ((t.rollover_count || 0) > 0) s += ` [rolled ${t.rollover_count}×]`\n    19→  return s\n    20→}\n    21→\n    22→// Called nightly at 8PM by Vercel cron (see vercel.json)\n    23→export default async function handler(req, res) {\n    24→  const authHeader = req.headers.authorization\n    25→  if (!process.env.CRON_SECRET || authHeader !== `Bearer ${process.env.CRON_SECRET}`) {\n    26→    return res.status(401).json({ error: 'Unauthorized' })\n    27→  }\n    28→\n    29→  const supabaseAdmin = getAdminClient()\n    30→\n    31→  // 1. Run nightly rollover\n    32→  let rolloverResult = { rolled: 0, tasks: [] }\n    33→  try {\n    34→    rolloverResult = await runRollover()\n    35→    console.log(`[evening-checkin] Rollover: ${rolloverResult.rolled} tasks moved`)\n    36→  } catch (err) {\n    37→    console.error('[evening-checkin] Rollover error:', err.message)\n    38→  }\n    39→\n    40→  // 2. Pre-generate evening check-in message for users who have evening check-ins enabled\n    41→  const { data: profiles } = await supabaseAdmin\n    42→    .from('profiles')\n    43→    .select('*')\n    44→    .contains('checkin_times', ['evening'])\n    45→\n    46→  if (!profiles || profiles.length === 0) {\n    47→    return res.status(200).json({ success: true, rolled: rolloverResult.rolled, pregenerated: 0 })\n    48→  }\n    49→\n    50→  let pregenerated = 0\n    51→\n    52→  await Promise.allSettled(profiles.map(async (profile) => {\n    53→    try {\n    54→      const { data: tasks = [] } = await supabaseAdmin\n    55→        .from('tasks').select('*').eq('user_id', profile.id).eq('archived', false)\n    56→\n    57→      const pending = (tasks || []).filter(t => !t.completed)\n    58→      const completed = (tasks || []).filter(t => t.completed)\n    59→      const rollovers = pending.filter(t => (t.rollover_count || 0) > 0)\n    60→      const name = profile.full_name?.split(' ')[0] || 'there'\n    61→\n    62→      const rolloverNote = rollovers.length > 0\n    63→        ? ` ${rollovers.length} task${rollovers.length !== 1 ? 's have' : ' has'} been rolling over.`\n    64→        : ''\n    65→      const contextPrompt = `It's evening. The day is wrapping up for ${name}. Completed: ${completed.length > 0 ? completed.map(fmtTask).join(', ') : 'none'}. Still pending (will roll to tomorrow): ${pending.length > 0 ? pending.map(fmtTask).join(', ') : 'none'}.${rolloverNote} Lead with wins first, always. Close with something that makes them feel good about showing up tomorrow. Under 4 sentences.`\n    66→\n    67→      const systemPrompt = buildPersonaPrompt(profile)\n    68→      const message = await coachingMessage(\n    69→        [{ role: 'user', content: contextPrompt }],\n    70→        systemPrompt\n    71→      )\n    72→\n    73→      await supabaseAdmin.from('profiles').update({\n    74→        last_checkin_message: message,\n    75→        last_checkin_at: new Date().toISOString()\n    76→      }).eq('id', profile.id)\n    77→\n    78→      pregenerated++\n    79→      console.log(`[evening-checkin] Pre-generated for ${name}`)\n    80→\n    81→      // 3. Create bill tasks due today or tomorrow\n    82→      try {\n    83→        const billResult = await runBillsToTasks(profile.id)\n    84→        if (billResult.created > 0) {\n    85→          console.log(`[evening-checkin] Bill tasks created for ${name}:`, billResult.bills)\n    86→        }\n    87→      } catch (billErr) {\n    88→        console.error(`[evening-checkin] Bill tasks failed for ${profile.id}:`, billErr.message)\n    89→      }\n    90→\n    91→      // 4. Save today's progress snapshot before the day ends\n    92→      try {\n    93→        await runProgressSnapshot(profile.id)\n    94→      } catch (snapErr) {\n    95→        console.error(`[evening-checkin] Progress snapshot failed for ${profile.id}:`, snapErr.message)\n    96→      }\n    97→    } catch (err) {\n    98→      console.error(`[evening-checkin] Pre-gen failed for ${profile.id}:`, err.message)\n    99→    }\n   100→  }))\n   101→\n   102→  // Send push notifications to all eligible evening users\n   103→  const userIds = profiles.map(p => p.id)\n   104→  try {\n   105→    await sendPushToUsers(supabaseAdmin, userIds, {\n   106→      title: 'End of day.',\n   107→      body: \"How'd it go? Take 2 minutes.\",\n   108→      tag: 'cinis-evening',\n   109→      url: '/dashboard'\n   110→    })\n   111→    console.log(`[evening-checkin] Push sent to ${userIds.length} users`)\n   112→  } catch (pushErr) {\n   113→    console.error('[evening-checkin] Batch push error:', pushErr.message)\n   114→  }\n   115→\n   116→  return res.status(200).json({ success: true, rolled: rolloverResult.rolled, pregenerated })\n   117→}\n   118→"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"007d5733-a617-44b6-bba5-be7b34c6d7d3","timestamp":"2026-03-26T12:03:53.286Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/api/cron/evening-checkin.js","content":"import { createClient } from '@supabase/supabase-js'\nimport { runRollover } from '../rollover-tasks'\nimport { runBillsToTasks } from '../bills-to-tasks'\nimport { runProgressSnapshot } from '../progress-snapshot'\nimport { buildPersonaPrompt } from '../../../lib/persona'\nimport { coachingMessage } from '../../../lib/anthropic'\nconst { sendPushToUsers } = require('../../../lib/push')\n\nfunction getAdminClient() {\n  return createClient(\n    process.env.NEXT_PUBLIC_SUPABASE_URL,\n    process.env.SUPABASE_SERVICE_ROLE_KEY\n  )\n}\n\nfunction fmtTask(t) {\n  let s = `\"${t.title}\"`\n  if ((t.rollover_count || 0) > 0) s += ` [rolled ${t.rollover_count}×]`\n  return s\n}\n\n// Called nightly at 8PM by Vercel cron (see vercel.json)\nexport default async function handler(req, res) {\n  const authHeader = req.headers.authorization\n  if (!process.env.CRON_SECRET || authHeader !== `Bearer ${process.env.CRON_SECRET}`) {\n    return res.status(401).json({ error: 'Unauthorized' })\n  }\n\n  const supabaseAdmin = getAdminClient()\n\n  // 1. Run nightly rollover\n  let rolloverResult = { rolled: 0, tasks: [] }\n  try {\n    rolloverResult = await runRollover()\n    console.log(`[evening-checkin] Rollover: ${rolloverResult.rolled} tasks moved`)\n  } catch (err) {\n    console.error('[evening-checkin] Rollover error:', err.message)\n  }\n\n  // 2. Pre-generate evening check-in message for users who have evening check-ins enabled\n  const { data: profiles } = await supabaseAdmin\n    .from('profiles')\n    .select('*')\n    .contains('checkin_times', ['evening'])\n\n  if (!profiles || profiles.length === 0) {\n    return res.status(200).json({ success: true, rolled: rolloverResult.rolled, pregenerated: 0 })\n  }\n\n  let pregenerated = 0\n\n  await Promise.allSettled(profiles.map(async (profile) => {\n    try {\n      const { data: tasks = [] } = await supabaseAdmin\n        .from('tasks').select('*').eq('user_id', profile.id).eq('archived', false)\n\n      const pending = (tasks || []).filter(t => !t.completed)\n      const completed = (tasks || []).filter(t => t.completed)\n      const rollovers = pending.filter(t => (t.rollover_count || 0) > 0)\n      const name = profile.full_name?.split(' ')[0] || 'there'\n\n      const rolloverNote = rollovers.length > 0\n        ? ` ${rollovers.length} task${rollovers.length !== 1 ? 's have' : ' has'} been rolling over.`\n        : ''\n      const contextPrompt = `It's evening. The day is wrapping up for ${name}. Completed: ${completed.length > 0 ? completed.map(fmtTask).join(', ') : 'none'}. Still pending (will roll to tomorrow): ${pending.length > 0 ? pending.map(fmtTask).join(', ') : 'none'}.${rolloverNote} Lead with wins first, always. Close with something that makes them feel good about showing up tomorrow. Under 4 sentences.`\n\n      const systemPrompt = buildPersonaPrompt(profile)\n      const message = await coachingMessage(\n        [{ role: 'user', content: contextPrompt }],\n        systemPrompt\n      )\n\n      await supabaseAdmin.from('profiles').update({\n        last_checkin_message: message,\n        last_checkin_at: new Date().toISOString()\n      }).eq('id', profile.id)\n\n      pregenerated++\n      console.log(`[evening-checkin] Pre-generated for ${name}`)\n\n      // 3. Create bill tasks due today or tomorrow\n      try {\n        const billResult = await runBillsToTasks(profile.id)\n        if (billResult.created > 0) {\n          console.log(`[evening-checkin] Bill tasks created for ${name}:`, billResult.bills)\n        }\n      } catch (billErr) {\n        console.error(`[evening-checkin] Bill tasks failed for ${profile.id}:`, billErr.message)\n      }\n\n      // 4. Save today's progress snapshot before the day ends\n      try {\n        await runProgressSnapshot(profile.id)\n      } catch (snapErr) {\n        console.error(`[evening-checkin] Progress snapshot failed for ${profile.id}:`, snapErr.message)\n      }\n    } catch (err) {\n      console.error(`[evening-checkin] Pre-gen failed for ${profile.id}:`, err.message)\n    }\n  }))\n\n  // Send push notifications to all eligible evening users\n  const userIds = profiles.map(p => p.id)\n  try {\n    await sendPushToUsers(supabaseAdmin, userIds, {\n      title: 'End of day.',\n      body: \"How'd it go? Take 2 minutes.\",\n      tag: 'cinis-evening',\n      url: '/dashboard'\n    })\n    console.log(`[evening-checkin] Push sent to ${userIds.length} users`)\n  } catch (pushErr) {\n    console.error('[evening-checkin] Batch push error:', pushErr.message)\n  }\n\n  return res.status(200).json({ success: true, rolled: rolloverResult.rolled, pregenerated })\n}\n","numLines":118,"startLine":1,"totalLines":118}}}
