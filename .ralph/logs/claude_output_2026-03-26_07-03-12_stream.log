{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BBqnYXQSKSY3vMz85N5b6k","type":"tool_result","content":"     1→const webpush = require('web-push');\n     2→\n     3→webpush.setVapidDetails(\n     4→  'mailto:ryan@cinis.app',\n     5→  process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY,\n     6→  process.env.VAPID_PRIVATE_KEY\n     7→);\n     8→\n     9→/**\n    10→ * Send a push notification to a single subscription\n    11→ * @param {object} subscription - PushSubscription object from DB\n    12→ * @param {object} payload - { title, body, tag, url }\n    13→ */\n    14→async function sendPushNotification(subscription, payload) {\n    15→  if (!subscription || !subscription.endpoint) return { success: false, reason: 'no_subscription' };\n    16→  try {\n    17→    await webpush.sendNotification(subscription, JSON.stringify(payload));\n    18→    return { success: true };\n    19→  } catch (err) {\n    20→    if (err.statusCode === 410 || err.statusCode === 404) {\n    21→      // Subscription expired/invalid — caller should clear it from DB\n    22→      return { success: false, reason: 'subscription_expired', statusCode: err.statusCode };\n    23→    }\n    24→    console.error('[push] sendPushNotification error:', err.message);\n    25→    return { success: false, reason: 'send_error', error: err.message };\n    26→  }\n    27→}\n    28→\n    29→/**\n    30→ * Send push notifications to multiple users by user_id array\n    31→ * Fetches their subscriptions from Supabase, skips those without push enabled\n    32→ * @param {object} supabase - service role Supabase client\n    33→ * @param {string[]} userIds\n    34→ * @param {object} payload - { title, body, tag, url }\n    35→ */\n    36→async function sendPushToUsers(supabase, userIds, payload) {\n    37→  if (!userIds || userIds.length === 0) return;\n    38→  const { data: profiles } = await supabase\n    39→    .from('profiles')\n    40→    .select('id, push_subscription, push_notifications_enabled')\n    41→    .in('id', userIds)\n    42→    .eq('push_notifications_enabled', true);\n    43→\n    44→  if (!profiles || profiles.length === 0) return;\n    45→\n    46→  const results = await Promise.allSettled(\n    47→    profiles.map(async (profile) => {\n    48→      if (!profile.push_subscription) return;\n    49→      const result = await sendPushNotification(profile.push_subscription, payload);\n    50→      if (result.reason === 'subscription_expired') {\n    51→        // Clear dead subscription\n    52→        await supabase\n    53→          .from('profiles')\n    54→          .update({ push_subscription: null, push_notifications_enabled: false })\n    55→          .eq('id', profile.id);\n    56→      }\n    57→      return result;\n    58→    })\n    59→  );\n    60→  return results;\n    61→}\n    62→\n    63→module.exports = { sendPushNotification, sendPushToUsers };\n    64→"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"cfa1dbb4-9a56-4a1f-a406-62efa0a8bc4f","timestamp":"2026-03-26T12:03:30.521Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/lib/push.js","content":"const webpush = require('web-push');\n\nwebpush.setVapidDetails(\n  'mailto:ryan@cinis.app',\n  process.env.NEXT_PUBLIC_VAPID_PUBLIC_KEY,\n  process.env.VAPID_PRIVATE_KEY\n);\n\n/**\n * Send a push notification to a single subscription\n * @param {object} subscription - PushSubscription object from DB\n * @param {object} payload - { title, body, tag, url }\n */\nasync function sendPushNotification(subscription, payload) {\n  if (!subscription || !subscription.endpoint) return { success: false, reason: 'no_subscription' };\n  try {\n    await webpush.sendNotification(subscription, JSON.stringify(payload));\n    return { success: true };\n  } catch (err) {\n    if (err.statusCode === 410 || err.statusCode === 404) {\n      // Subscription expired/invalid — caller should clear it from DB\n      return { success: false, reason: 'subscription_expired', statusCode: err.statusCode };\n    }\n    console.error('[push] sendPushNotification error:', err.message);\n    return { success: false, reason: 'send_error', error: err.message };\n  }\n}\n\n/**\n * Send push notifications to multiple users by user_id array\n * Fetches their subscriptions from Supabase, skips those without push enabled\n * @param {object} supabase - service role Supabase client\n * @param {string[]} userIds\n * @param {object} payload - { title, body, tag, url }\n */\nasync function sendPushToUsers(supabase, userIds, payload) {\n  if (!userIds || userIds.length === 0) return;\n  const { data: profiles } = await supabase\n    .from('profiles')\n    .select('id, push_subscription, push_notifications_enabled')\n    .in('id', userIds)\n    .eq('push_notifications_enabled', true);\n\n  if (!profiles || profiles.length === 0) return;\n\n  const results = await Promise.allSettled(\n    profiles.map(async (profile) => {\n      if (!profile.push_subscription) return;\n      const result = await sendPushNotification(profile.push_subscription, payload);\n      if (result.reason === 'subscription_expired') {\n        // Clear dead subscription\n        await supabase\n          .from('profiles')\n          .update({ push_subscription: null, push_notifications_enabled: false })\n          .eq('id', profile.id);\n      }\n      return result;\n    })\n  );\n  return results;\n}\n\nmodule.exports = { sendPushNotification, sendPushToUsers };\n","numLines":64,"startLine":1,"totalLines":64}}}
