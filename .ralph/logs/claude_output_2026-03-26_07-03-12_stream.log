{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DmRiQqCDj61SEqUFwR8Fsb","type":"tool_result","content":"     1→import { createClient } from '@supabase/supabase-js'\n     2→import withAuth from '../../../lib/authGuard'\n     3→const { sendPushNotification } = require('../../../lib/push')\n     4→\n     5→function getAdminClient() {\n     6→  return createClient(\n     7→    process.env.NEXT_PUBLIC_SUPABASE_URL,\n     8→    process.env.SUPABASE_SERVICE_ROLE_KEY\n     9→  )\n    10→}\n    11→\n    12→async function handler(req, res, userId) {\n    13→  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n    14→\n    15→  const supabase = getAdminClient()\n    16→\n    17→  const { data: profile } = await supabase\n    18→    .from('profiles')\n    19→    .select('push_subscription, push_notifications_enabled, full_name')\n    20→    .eq('id', userId)\n    21→    .single()\n    22→\n    23→  if (!profile?.push_notifications_enabled || !profile?.push_subscription) {\n    24→    return res.status(400).json({ error: 'Push notifications not enabled' })\n    25→  }\n    26→\n    27→  const firstName = (profile.full_name || 'there').split(' ')[0]\n    28→  const result = await sendPushNotification(profile.push_subscription, {\n    29→    title: 'Cinis',\n    30→    body: `Notifications are working, ${firstName}. You'll hear from us.`,\n    31→    tag: 'cinis-test',\n    32→    url: '/dashboard'\n    33→  })\n    34→\n    35→  if (!result.success) return res.status(500).json({ error: result.reason })\n    36→  return res.status(200).json({ success: true })\n    37→}\n    38→\n    39→export default withAuth(handler)\n    40→"}]},"parent_tool_use_id":null,"session_id":"fdbc200a-ad61-40f1-afb6-ec011de01e9b","uuid":"62cbef66-6b50-4f04-a8a2-394eba9f5fba","timestamp":"2026-03-26T12:03:39.634Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ryanjohnson/Documents/focusbuddy-app/pages/api/notifications/send-test.js","content":"import { createClient } from '@supabase/supabase-js'\nimport withAuth from '../../../lib/authGuard'\nconst { sendPushNotification } = require('../../../lib/push')\n\nfunction getAdminClient() {\n  return createClient(\n    process.env.NEXT_PUBLIC_SUPABASE_URL,\n    process.env.SUPABASE_SERVICE_ROLE_KEY\n  )\n}\n\nasync function handler(req, res, userId) {\n  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })\n\n  const supabase = getAdminClient()\n\n  const { data: profile } = await supabase\n    .from('profiles')\n    .select('push_subscription, push_notifications_enabled, full_name')\n    .eq('id', userId)\n    .single()\n\n  if (!profile?.push_notifications_enabled || !profile?.push_subscription) {\n    return res.status(400).json({ error: 'Push notifications not enabled' })\n  }\n\n  const firstName = (profile.full_name || 'there').split(' ')[0]\n  const result = await sendPushNotification(profile.push_subscription, {\n    title: 'Cinis',\n    body: `Notifications are working, ${firstName}. You'll hear from us.`,\n    tag: 'cinis-test',\n    url: '/dashboard'\n  })\n\n  if (!result.success) return res.status(500).json({ error: result.reason })\n  return res.status(200).json({ success: true })\n}\n\nexport default withAuth(handler)\n","numLines":40,"startLine":1,"totalLines":40}}}
